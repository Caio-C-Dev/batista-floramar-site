@model BatistaFloramar.Models.NovoBatizadoViewModel
@{
    Layout = "~/Views/Shared/_BatismoAreaLayout.cshtml";
}

<div class="admin-card" style="max-width: 540px;">
    <form method="post" asp-action="NovoBatizado" asp-controller="AreaBatismo" novalidate>
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="Nome" class="form-label"></label>
            <input asp-for="Nome" class="form-control" placeholder="Nome completo do batizado" />
            <span asp-validation-for="Nome" class="field-validation-error"></span>
        </div>

        <div class="mb-3">
            <label asp-for="DataBatismo" class="form-label"></label>
            <input asp-for="DataBatismo" type="date" class="form-control" />
            <span asp-validation-for="DataBatismo" class="field-validation-error"></span>
        </div>

        <div class="mb-3">
            <label asp-for="WhatsApp" class="form-label"></label>
            <input asp-for="WhatsApp" class="form-control" placeholder="(31) 99999-9999" />
        </div>

        <div class="mb-4">
            <label asp-for="Observacoes" class="form-label"></label>
            <textarea asp-for="Observacoes" class="form-control" rows="3"
                      placeholder="Observações sobre este batismo (opcional)..."></textarea>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn-admin">
                <i class="fas fa-save me-1"></i> Salvar
            </button>
            <a href="@Url.Action("Batizados", "AreaBatismo")" class="btn-admin-outline">Cancelar</a>
        </div>
    </form>
</div>
