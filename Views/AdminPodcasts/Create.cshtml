@using BatistaFloramar.Domain.Entities
@model PodcastVideo
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Novo Vídeo";
    ViewBag.AdminSection = "podcasts";
}

@section TopbarActions {
    <a href="@Url.Action("Index")" class="btn-admin-outline">
        <i class="fas fa-arrow-left"></i> Voltar
    </a>
}

<div class="admin-card" style="max-width: 620px;">
    <form method="post" asp-action="Create" class="admin-form">
        @Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-12">
                <label asp-for="Titulo">Título</label>
                <input asp-for="Titulo" class="form-control" placeholder="Ex.: Culto 01/01/2025" />
                <span asp-validation-for="Titulo" class="field-validation-error"></span>
            </div>
            <div class="col-12">
                <label asp-for="Descricao">Descrição (opcional)</label>
                <textarea asp-for="Descricao" class="form-control" rows="2" placeholder="Breve descrição do vídeo..."></textarea>
            </div>
            <div class="col-md-8">
                <label asp-for="YoutubeVideoId">ID do Vídeo no YouTube</label>
                <input asp-for="YoutubeVideoId" class="form-control" placeholder="Ex.: KwNGBInZFHI" />
                <span class="text-muted">Apenas o ID, não a URL completa.</span>
                <span asp-validation-for="YoutubeVideoId" class="field-validation-error"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="StartSeconds">Início (segundos)</label>
                <input asp-for="StartSeconds" type="number" class="form-control" min="0" placeholder="Ex.: 3240" />
                <span class="text-muted">Opcional. 0 = início.</span>
            </div>
            <div class="col-md-6">
                <label asp-for="DataPublicacao">Data de Publicação</label>
                <input asp-for="DataPublicacao" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-6">
                <label asp-for="Ordem">Ordem de exibição</label>
                <input asp-for="Ordem" type="number" class="form-control" min="0" />
            </div>
            <div class="col-12">
                <div class="form-check">
                    <input asp-for="Ativo" class="form-check-input" type="checkbox" checked />
                    <label asp-for="Ativo" class="form-check-label" style="text-transform:none; font-size: 0.9rem; color: var(--admin-text);">
                        Vídeo ativo (visível no site)
                    </label>
                </div>
            </div>
            <div class="col-12 pt-2">
                <button type="submit" class="btn-admin">
                    <i class="fas fa-save"></i> Salvar Vídeo
                </button>
            </div>
        </div>
    </form>
</div>
