@{
    ViewBag.Title = "Doação";
    ViewBag.MetaDescription = "Contribua com a Comunidade Batista Floramar e ajude a sustentar a obra de Deus em Belo Horizonte. Doação via Pix ou cartão.";
    Layout = "_Layout";
}

<div class="page-card">
    <div class="page-header">
        <span class="section-eyebrow">Contribua com Alegria</span>
        <h1 class="page-title">Doações</h1>
        <p class="page-subtitle">
            Sua oferta é um ato de adoração. Contribua com a Comunidade Batista Floramar de forma rápida e segura.
            — <em>2 Coríntios 9:7</em>
        </p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4 mt-2">
        <div class="col">
            <div class="section-card donation-select-card h-100 text-center" onclick="selectDonacao('doacao', this)">
                <span class="selected-badge">SELECIONADO</span>
                <div class="about-pillar-icon-lg"><i class="fas fa-heart"></i></div>
                <h3>Doação</h3>
                <p class="text-secondary">Oferta geral para ajudar a comunidade a manter seus projetos e ministérios.</p>
                <button type="button" class="donation-select-btn">
                    <i class="fas fa-qrcode"></i> Contribuir via PIX
                </button>
            </div>
        </div>
        <div class="col">
            <div class="section-card donation-select-card h-100 text-center" onclick="selectDonacao('dizimo', this)">
                <span class="selected-badge">SELECIONADO</span>
                <div class="about-pillar-icon-lg"><i class="fas fa-percentage"></i></div>
                <h3>Dízimo</h3>
                <p class="text-secondary">Contribuição mensal para sustentar o ministério e o trabalho da igreja.</p>
                <button type="button" class="donation-select-btn">
                    <i class="fas fa-qrcode"></i> Contribuir via PIX
                </button>
            </div>
        </div>
        <div class="col">
            <div class="section-card donation-select-card h-100 text-center" onclick="selectDonacao('oferta', this)">
                <span class="selected-badge">SELECIONADO</span>
                <div class="about-pillar-icon-lg"><i class="fas fa-gift"></i></div>
                <h3>Oferta</h3>
                <p class="text-secondary">Oferta especial de gratidão para momentos de bênção e celebração.</p>
                <button type="button" class="donation-select-btn">
                    <i class="fas fa-qrcode"></i> Contribuir via PIX
                </button>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2" id="pix">
        <div class="col-md-6">
            <div class="section-card h-100 text-center" id="pix-card">
                <h3><i class="fas fa-qrcode me-2 text-gold"></i>PIX</h3>
                <p class="text-secondary mb-3">Escaneie o QR Code ou copie a chave CNPJ abaixo para contribuir instantaneamente.</p>
                <img src="~/images/qr_code.png"
                     alt="QR Code PIX Comunidade Batista Floramar"
                     class="img-fluid pix-qr-img mb-3"
                     onerror="this.style.display='none'" />
                <div class="pix-key-box rounded-3 p-3 mb-3">
                    <p class="mb-1 text-secondary small">Chave PIX (CNPJ)</p>
                    <strong class="text-gold fs-5">44.457.832/0001-07</strong>
                </div>
                <button type="button" class="btn btn-primary" onclick="navigator.clipboard.writeText('44.457.832/0001-07');this.innerHTML='<i class=\'fas fa-check me-2\'></i> Copiado!'">
                    <i class="fas fa-copy me-2"></i> Copiar chave
                </button>
            </div>
        </div>
        <div class="col-md-6">
            <div class="section-card h-100">
                <h3><i class="fas fa-info-circle me-2 text-gold"></i>Por que contribuir?</h3>
                <ul class="info-list mt-2">
                    <li><i class="fas fa-check-circle"></i><span>Sustento do ministério e da equipe pastoral</span></li>
                    <li><i class="fas fa-check-circle"></i><span>Projetos de ação social e missões</span></li>
                    <li><i class="fas fa-check-circle"></i><span>Manutenção e crescimento da comunidade</span></li>
                    <li><i class="fas fa-check-circle"></i><span>Apoio a famílias em necessidade</span></li>
                    <li><i class="fas fa-check-circle"></i><span>Ministério com crianças e jovens</span></li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function selectDonacao(type, card) {
        // Remove selected state from all cards
        document.querySelectorAll('.donation-select-card').forEach(function (c) {
            c.classList.remove('selected');
        });
        // Mark this card as selected
        card.classList.add('selected');

        // Smooth scroll to PIX section
        var pixSection = document.getElementById('pix');
        if (pixSection) {
            pixSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        // Highlight the PIX card briefly
        var pixCard = document.getElementById('pix-card');
        if (pixCard) {
            pixCard.classList.remove('pix-section-highlight');
            // Force reflow to restart animation
            void pixCard.offsetWidth;
            pixCard.classList.add('pix-section-highlight');
            setTimeout(function () { pixCard.classList.remove('pix-section-highlight'); }, 1700);
        }
    }
</script>
}