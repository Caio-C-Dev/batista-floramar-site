@{
    ViewBag.Title = "Sobre";
    Layout = "_Layout";
}

<div class="page-card">
    <div class="page-header">
        <span class="section-eyebrow">Quem Somos</span>
        <h1 class="page-title">Sobre a Comunidade Batista Floramar</h1>
        <p class="page-subtitle">
            Uma igreja bíblica, comprometida com a Palavra e com as pessoas, no coração de Belo Horizonte.
        </p>
    </div>

    <div class="row g-4 mt-2">
        <div class="col-lg-8">
            <div class="section-card h-100">
                <h3><i class="fas fa-church me-2 text-gold"></i>Nossa História</h3>
                <p class="text-secondary">
                    A Comunidade Batista Floramar existe para glorificar a Deus através do amor a Ele, ao próximo e à Sua Palavra.
                    Somos uma congregação fiel à missão de pregar o Evangelho, discipular vidas e fortalecer famílias.
                </p>
                <p class="text-secondary">
                    Comprometida com a Grande Comissão, a igreja caminha junto com a comunidade do bairro Floramar e região,
                    levando esperança, restauração e o amor de Cristo a cada lar.
                </p>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="section-card h-100">
                <h3><i class="fas fa-map-marker-alt me-2 text-gold"></i>Endereço</h3>
                <p class="text-secondary mb-1">R. José Lima de Almeida, 59</p>
                <p class="text-secondary mb-1">Jardim Guanabara</p>
                <p class="text-secondary mb-1">Belo Horizonte — MG</p>
                <p class="text-secondary">CEP: 31742-033</p>
            </div>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4 mt-2">
        <div class="col">
            <div class="section-card h-100 text-center">
                <div class="about-pillar-icon-lg"><i class="fas fa-book"></i></div>
                <h4>Palavra</h4>
                <p class="text-secondary">Pregando e ensinando as verdades imutáveis da Bíblia com fidelidade e clareza.</p>
            </div>
        </div>
        <div class="col">
            <div class="section-card h-100 text-center">
                <div class="about-pillar-icon-lg"><i class="fas fa-hands-helping"></i></div>
                <h4>Comunhão</h4>
                <p class="text-secondary">Valorizamos a vida em comunidade genuína, onde cada pessoa é bem-vinda e amada.</p>
            </div>
        </div>
        <div class="col">
            <div class="section-card h-100 text-center">
                <div class="about-pillar-icon-lg"><i class="fas fa-globe"></i></div>
                <h4>Missão</h4>
                <p class="text-secondary">Vocacionados para servir, alcançar o perdido e impactar a cidade com o Evangelho.</p>
            </div>
        </div>
    </div>

    <div class="section-card mt-4">
        <h3><i class="fas fa-bullseye me-2 text-gold"></i>Nossa Missão e Visão</h3>
        <div class="row g-4 mt-1">
            <div class="col-md-6">
                <h5 class="text-gold">Missão</h5>
                <p class="text-secondary">
                    Glorificar a Deus fazendo discípulos de todas as nações, ensinando-os a guardar tudo o que Cristo ordenou.
                </p>
            </div>
            <div class="col-md-6">
                <h5 class="text-gold">Visão</h5>
                <p class="text-secondary">
                    Ser uma igreja que transforma vidas através da Palavra, impacta comunidades pelo serviço e glorifica a Deus por meio da adoração.
                </p>
            </div>
        </div>
    </div>

    <div class="section-card mt-4">
        <h3><i class="fas fa-user-tie me-2 text-gold"></i>Nossa Liderança Pastoral</h3>
        <div class="row g-4 mt-1">
            <div class="col-md-6">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <img src="~/images/Pastor.jpg" alt="Pr. Rodrigo N. Ferreira" class="rounded-circle" style="width:80px;height:80px;object-fit:cover;">
                    <div>
                        <h5 class="mb-0">Pr. Rodrigo N. Ferreira</h5>
                        <p class="text-gold mb-0 small">Pastor Presidente</p>
                    </div>
                </div>
                <p class="text-secondary">
                    Responsável pela pregação e ensino nos cultos de domingo, liderando a congregação com dedicação e compromisso com a Palavra de Deus.
                </p>
            </div>
            <div class="col-md-6">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <img src="~/images/Delmo.jpeg" alt="Pr. Delmo Gonçalves" class="rounded-circle" style="width:80px;height:80px;object-fit:cover;flex-shrink:0;">
                    <div>
                        <h5 class="mb-0">Pr. Delmo Gonçalves</h5>       
                        <p class="text-gold mb-0 small">Pastor da Família</p>
                    </div>
                </div>
                <p class="text-secondary">
                    Responsável pelos cultos de quarta-feira, ministrando a Palavra com sabedoria e cuidado pastoral para toda a família.
                </p>
            </div>
        </div>
    </div>
</div>
