@{
    ViewBag.Title = "Sobre | Comunidade Batista Floramar BH";
    Layout = "_Layout";
    ViewBag.FullWidth = true;
}

<script type="application/ld+json">
{
  "@@context": "https://schema.org",
  "@@type": "WebPage",
  "name": "Sobre – Comunidade Batista Floramar",
  "description": "Conheça a história, visão, missão e liderança da Comunidade Batista Floramar em Floramar, Belo Horizonte.",
  "url": "https://www.batistafloramar.com.br/Sobre",
  "breadcrumb": {
    "@@type": "BreadcrumbList",
    "itemListElement": [
      { "@@type": "ListItem", "position": 1, "name": "Início", "item": "https://www.batistafloramar.com.br/" },
      { "@@type": "ListItem", "position": 2, "name": "Sobre", "item": "https://www.batistafloramar.com.br/Sobre" }
    ]
  },
  "isPartOf": { "@@id": "https://www.batistafloramar.com.br/#church" }
}
</script>
<style>
    .sobre-hero {
        background: radial-gradient(ellipse at top, var(--bg-tertiary) 0%, var(--bg-primary) 60%);
        padding: 5.5rem 0 4rem;
        text-align: center;
        border-bottom: 1px solid var(--brand-gold-border);
        position: relative;
        overflow: hidden;
    }
    .sobre-hero::before {
        content: '';
        position: absolute; inset: 0;
        background: radial-gradient(ellipse 60% 50% at 50% 100%, var(--brand-gold-light) 0%, transparent 70%);
    }
    .sobre-hero h1 { font-size: clamp(2rem,5vw,3.2rem); font-weight: 800; color: var(--text-primary); margin-bottom: 1rem; position: relative; }
    .sobre-hero .section-eyebrow { position: relative; }
    .sobre-hero p { color: var(--text-secondary); max-width: 620px; margin: 0 auto; font-size: 1.1rem; position: relative; }

    .sobre-section { padding: 4.5rem 0; }
    .sobre-section.alt { background: var(--bg-secondary); }

    .sobre-card {
        background: var(--bg-tertiary);
        border: 1px solid rgba(255,255,255,.07);
        border-radius: calc(var(--radius) * 1.5);
        padding: 2rem;
        height: 100%;
        position: relative;
        overflow: hidden;
        transition: transform var(--transition-smooth), box-shadow var(--transition-smooth), border-color var(--transition-smooth);
    }
    .sobre-card::before {
        content: '';
        position: absolute; inset: 0;
        background: linear-gradient(-30deg, hsla(0,0%,0%,0) 60%, rgba(255,255,255,0.25) 70%, hsla(0,0%,0%,0) 80%);
        background-size: 300% 300%;
        background-repeat: no-repeat;
        background-position: -100% -100%;
        transition: 800ms ease;
        pointer-events: none; z-index: 1;
    }
    .sobre-card:hover::before { background-position: 100% 100%; }
    .sobre-card > * { position: relative; z-index: 2; }
    .sobre-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-hover); border-color: var(--brand-gold-border); }

    .sobre-card-icon {
        width: 66px; height: 66px; margin: 0 auto 1rem;
        background: var(--brand-gold-light); border: 1px solid var(--brand-gold-border);
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        font-size: 1.6rem; color: var(--brand-gold);
    }
    .sobre-card h3, .sobre-card h4 { color: var(--text-primary); font-weight: 700; margin-bottom: .75rem; }
    .sobre-card p { color: var(--text-secondary); font-size: .95rem; }

    .visao-item {
        padding: 1.75rem;
        background: var(--bg-tertiary);
        border-radius: var(--radius);
        border: 1px solid rgba(255,255,255,.06);
        height: 100%;
        transition: border-color var(--transition-smooth);
    }
    .visao-item:hover { border-color: var(--brand-gold-border); }
    .visao-item h5 { font-weight: 700; margin-bottom: .5rem; }

    .lideranca-card {
        background: var(--bg-tertiary);
        border: 1px solid rgba(255,255,255,.07);
        border-radius: calc(var(--radius) * 1.5);
        padding: 2rem;
        height: 100%;
        transition: border-color var(--transition-smooth);
    }
    .lideranca-card:hover { border-color: var(--brand-gold-border); }
    .lideranca-card img { width: 90px; height: 90px; object-fit: cover; flex-shrink: 0; border: 2px solid var(--brand-gold-border); }

    .cta-block {
        background: var(--bg-secondary);
        border-top: 1px solid var(--brand-gold-border);
        padding: 5rem 0;
        text-align: center;
    }
    .cta-block h2 { color: var(--text-primary); font-weight: 700; font-size: clamp(1.5rem,3vw,2rem); margin-bottom: .75rem; }
    .cta-block p { color: var(--text-secondary); max-width: 540px; margin: 0 auto 2rem; }
</style>

<!-- Hero -->
<div class="sobre-hero">
    <div class="container">
        <span class="section-eyebrow">Quem Somos</span>
        <h1>Sobre a Comunidade Batista Floramar</h1>
        <p>Uma igreja Bíblica, comprometida com a Palavra e com as pessoas, no coração de Belo Horizonte.</p>
    </div>
</div>

<!-- História + Endereço -->
<div class="sobre-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-8 scroll-reveal">
                <div class="sobre-card">
                    <h3><i class="fas fa-church me-2 text-gold"></i>Nossa História</h3>
                    <p>A Comunidade Batista Floramar nasceu de um projeto iniciado pela Igreja Batista da Lagoinha, presidida pelo honrado pastor Márcio Valadão. Nasce a primeira igreja em Belo Horizonte fora da sede. Um começo promissor que vive até seus 9 anos. Em dezembro do ano de 2019, um jovem brasiliense vem para assumir a igreja. Hoje, essa igreja leva o nome de Comunidade Batista Floramar por sua emancipação da Lagoinha e segue rompendo os desafios de uma igreja local.</p>
                    <p>Nosso pastor, Rodrigo N. Ferreira é o pastor presidente e a visão dele é a transformação de vidas pela, simples, pregação do evangelho de forma expositiva. Ele acredita que, através da exposição das Escrituras, temos tudo que precisamos, sem misturas ideológicas, políticas e seculares. Ele não acredita que os eventos, campanhas, crendices e festas, vão trazer mudança no caráter e conversão genuína. Mas sim, pela simples pregação do evangelho e a comunhão verdadeira.</p>
                    <p class="mb-0">Nossa igreja existe para glorificar a Deus através do amor a Ele, ao próximo e à Sua Palavra. Somos uma congregação fiel à missão de pregar o Evangelho, discipular vidas e fortalecer famílias. Comprometida com a Grande Comissão, a igreja caminha junto com a comunidade do bairro Floramar e região, levando esperança, restauração e o amor de Cristo a cada lar.</p>
                </div>
            </div>
            <div class="col-lg-4 scroll-reveal delay-1">
                <div class="sobre-card">
                    <h3><i class="fas fa-map-marker-alt me-2 text-gold"></i>Endereço</h3>
                    <p class="mb-1">Rua José Lima de Almeida, 59</p>
                    <p class="mb-1">Floramar</p>
                    <p class="mb-1">Belo Horizonte — MG</p>
                    <p class="mb-0">CEP: 31710-140</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Pilares -->
<div class="sobre-section alt">
    <div class="container">
        <div class="text-center mb-5 scroll-reveal">
            <span class="section-eyebrow">Nossos Pilares</span>
            <h2 class="section-heading">O que nos move</h2>
        </div>
        <div class="row row-cols-1 row-cols-md-3 g-4">
            <div class="col">
                <div class="sobre-card text-center scroll-reveal delay-1">
                    <div class="sobre-card-icon"><i class="fas fa-book"></i></div>
                    <h4>Palavra</h4>
                    <p class="mb-0">Pregando e ensinando as verdades imutáveis da Bíblia com fidelidade e clareza.</p>
                </div>
            </div>
            <div class="col">
                <div class="sobre-card text-center scroll-reveal delay-2">
                    <div class="sobre-card-icon"><i class="fas fa-hands-helping"></i></div>
                    <h4>Comunhão</h4>
                    <p class="mb-0">Acreditamos na comunhão em célula, nos ministérios e pós cultos, pois valorizamos a vida em comunidade genuína, onde cada pessoa é bem-vinda e amada.</p>
                </div>
            </div>
            <div class="col">
                <div class="sobre-card text-center scroll-reveal delay-3">
                    <div class="sobre-card-icon"><i class="fas fa-globe"></i></div>
                    <h4>Missão</h4>
                    <p class="mb-0">Vocacionados para servir, alcançar o perdido e impactar a cidade com o Evangelho.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Visão, Missão, Objetivo -->
<div class="sobre-section">
    <div class="container">
        <div class="text-center mb-5 scroll-reveal">
            <span class="section-eyebrow">Propósito</span>
            <h2 class="section-heading">Nossa Visão, Missão e Objetivo</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4 scroll-reveal delay-1">
                <div class="visao-item">
                    <h5 class="text-gold"><i class="fas fa-bullseye me-2"></i>Visão</h5>
                    <p class="text-secondary small fst-italic mb-1">1 Timóteo 2:4</p>
                    <p class="text-secondary mb-0">Que todos sejam salvos e cheguem ao pleno conhecimento da verdade.</p>
                </div>
            </div>
            <div class="col-md-4 scroll-reveal delay-2">
                <div class="visao-item">
                    <h5 class="text-gold"><i class="fas fa-compass me-2"></i>Missão</h5>
                    <p class="text-secondary mb-0">Cada membro, um conhecedor da Bíblia através da pregação expositiva da Palavra!</p>
                </div>
            </div>
            <div class="col-md-4 scroll-reveal delay-3">
                <div class="visao-item">
                    <h5 class="text-gold"><i class="fas fa-flag me-2"></i>Objetivo</h5>
                    <p class="text-secondary mb-0">Fazer conhecido o evangelho de JESUS CRISTO com o compromisso de pregar a BÍBLIA no púlpito, nas células e no dia comum, tendo como base a comunhão em amor.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Liderança -->
<div class="sobre-section alt">
    <div class="container">
        <div class="text-center mb-5 scroll-reveal">
            <span class="section-eyebrow">Pastoral</span>
            <h2 class="section-heading">Nossa Liderança Pastoral</h2>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-md-5 scroll-reveal delay-1">
                <div class="lideranca-card">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <img src="~/images/PrRodrigo.jpeg" alt="Pr. Rodrigo N. Ferreira" class="rounded-circle">
                        <div>
                            <h5 class="mb-0">Pr. Rodrigo N. Ferreira</h5>
                            <p class="text-gold mb-0 small">Pastor Presidente</p>
                        </div>
                    </div>
                    <p class="text-secondary mb-0">Responsável pela pregação e ensino nos cultos de domingo, liderando a congregação com dedicação e compromisso com a Palavra de Deus.</p>
                </div>
            </div>
            <div class="col-md-5 scroll-reveal delay-2">
                <div class="lideranca-card">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <img src="~/images/PrDelmo.jpeg" alt="Pr. Delmo Gonçalves e Pra. Dinéia Gonçalves" class="rounded-circle">
                        <div>
                            <h5 class="mb-0">Pr. Delmo Gonçalves<br>e Pra. Dinéia Gonçalves</h5>
                            <p class="text-gold mb-0 small">Pastores da Família</p>
                        </div>
                    </div>
                    <p class="text-secondary mb-0">Responsáveis pelo ministério da família, ministrando a Palavra com sabedoria e cuidado pastoral para toda a congregação.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- CTA -->
<div class="cta-block">
    <div class="container">
        <h2>Quer conhecer a gente pessoalmente?</h2>
        <p>Venha participar de um culto e fazer parte desta família.</p>
        <div class="d-flex flex-wrap justify-content-center gap-3">
            <a href="/Visita" class="btn btn-primary btn-lg">
                <i class="fas fa-map-marker-alt me-2"></i> Planejar Visita
            </a>
            <a href="https://wa.me/5531992898901?text=Olá!%20Gostaria%20de%20saber%20mais%20sobre%20a%20Comunidade%20Batista%20Floramar."
               target="_blank" rel="noopener noreferrer" class="btn btn-outline-hero btn-lg">
                <i class="fab fa-whatsapp me-2"></i> Falar no WhatsApp
            </a>
        </div>
    </div>
</div>
