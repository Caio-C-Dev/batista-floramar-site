@{
    ViewBag.Title = "Ao Vivo";
    Layout = "_Layout";
}

<div class="page-card">
    <div class="page-header">
        <span class="section-eyebrow">Transmissões Online</span>
        <h1 class="page-title">Ao Vivo</h1>
        <p class="page-subtitle">
            Acompanhe os cultos e eventos da Comunidade Batista Floramar ao vivo pelo YouTube, de onde você estiver.
        </p>
    </div>

    <div class="row g-4 mt-2">
        <div class="col-md-6">
            <div class="section-card h-100">
                <h3><i class="fas fa-broadcast-tower me-2 text-gold"></i>Transmissões da semana</h3>
                <p class="text-secondary">Todos os cultos são transmitidos ao vivo com louvor, oração e mensagem Bíblica.</p>
                <ul class="info-list mt-3">
                    <li><i class="fas fa-sun"></i><span><strong>Domingo</strong> — 10h00 (Culto da Manhã)</span></li>
                    <li><i class="fas fa-users"></i><span><strong>Quarta</strong> — 20h00 (Culto de Família)</span></li>
                </ul>
            </div>
        </div>
        <div class="col-md-6">
            <div class="section-card h-100 text-center d-flex flex-column align-items-center justify-content-center gap-3">
                <div class="about-pillar-icon-lg"><i class="fab fa-youtube"></i></div>
                <h3>Canal Oficial</h3>
                <p class="text-secondary">Inscreva-se no canal para receber notificações das transmissões ao vivo e acessar o arquivo de cultos anteriores.</p>
                <a class="btn btn-primary btn-lg" href="https://www.youtube.com/@@comunidadebatistafloramar" target="_blank" rel="noopener noreferrer">
                    <i class="fab fa-youtube me-2"></i> Ir para o Canal
                </a>
            </div>
        </div>
    </div>
</div>

