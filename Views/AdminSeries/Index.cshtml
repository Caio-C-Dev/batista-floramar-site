@model List<BatistaFloramar.Domain.Entities.SerieMensagem>
@{
    Layout = "_AdminLayout";
    ViewBag.Title = "Séries de Mensagens";
    ViewBag.AdminSection = "series";
}
@section TopbarActions {
    <a href="@Url.Action("Nova")" class="btn-admin btn-admin-success">
        <i class="fas fa-plus"></i> Nova Série
    </a>
}
<div class="admin-card">
    <div class="form-text mb-3" style="color:var(--admin-text-muted);">
        <i class="fab fa-youtube me-1 text-danger"></i>
        Para encontrar o ID da playlist: abra a playlist no YouTube → a URL será <code style="color:#8af;">youtube.com/playlist?list=<strong>PLxxxxxx</strong></code> — copie o trecho após <code style="color:#8af;">list=</code>
    </div>
    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fab fa-youtube"></i>
            <p>Nenhuma série cadastrada ainda.</p>
            <a href="@Url.Action("Nova")" class="btn-admin btn-admin-success"><i class="fas fa-plus"></i> Adicionar primeira série</a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var s in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="admin-card" style="margin:0;padding:1rem;">
                        <div style="position:relative;height:140px;border-radius:8px;overflow:hidden;margin-bottom:.75rem;background:#0d1b3e;">
                            @if (!string.IsNullOrEmpty(s.ImagemCapa))
                            {
                                <img src="@s.ImagemCapa" style="width:100%;height:100%;object-fit:cover;filter:brightness(.8);" />
                            }
                            else
                            {
                                <div style="height:100%;display:flex;align-items:center;justify-content:center;">
                                    <i class="fab fa-youtube" style="font-size:3rem;color:#ff4444;"></i>
                                </div>
                            }
                            @if (!s.Ativo)
                            {
                                <span style="position:absolute;top:8px;right:8px;background:rgba(0,0,0,.7);color:#888;font-size:.7rem;padding:.2rem .5rem;border-radius:4px;">Inativa</span>
                            }
                        </div>
                        <h5 style="color:#fff;margin:0 0 .3rem;font-size:.95rem;">@s.Nome</h5>
                        @if (!string.IsNullOrEmpty(s.Descricao))
                        {
                            <p style="color:var(--admin-text-muted);font-size:.8rem;margin:0 0 .75rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">@s.Descricao</p>
                        }
                        <div class="d-flex gap-2 mt-2">
                            <a href="https://www.youtube.com/playlist?list=@s.PlaylistId" target="_blank"
                               class="btn-admin btn-admin-outline" style="font-size:.75rem;padding:.25rem .6rem;color:#ff6060;">
                                <i class="fab fa-youtube"></i> Ver
                            </a>
                            <a href="@Url.Action("Editar", new { id = s.Id })"
                               class="btn-admin btn-admin-outline" style="font-size:.75rem;padding:.25rem .6rem;">
                                <i class="fas fa-edit"></i> Editar
                            </a>
                            <form method="post" action="@Url.Action("Excluir", new { id = s.Id })"
                                  onsubmit="return confirm('Excluir a série \'@s.Nome\'?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-admin btn-admin-danger" style="font-size:.75rem;padding:.25rem .6rem;">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
