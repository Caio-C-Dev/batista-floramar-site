@{
    ViewBag.Title = "Missões";
    Layout = "_Layout";
}

<div class="page-card">
    <div class="page-header">
        <span class="section-eyebrow">Levando o Evangelho</span>
        <h1 class="page-title">Missões</h1>
        <p class="page-subtitle">
            Conheça os projetos e relatos da Comunidade Batista Floramar no campo missionário, local e além-fronteiras.
        </p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4 mt-2">
        <div class="col">
            <div class="section-card h-100">
                <img src="https://images.unsplash.com/photo-1526304640581-d334cdbbf45e?auto=format&fit=crop&w=800&q=80" alt="Missão Comunidade Esperança" class="img-fluid rounded mb-3" />
                <h3>Comunidade Esperança</h3>
                <p class="text-secondary">Distribuição de cestas e ação social em bairro carente de BH.</p>
                <a href="#missao1" class="btn btn-secondary mt-2">Ler relato</a>
            </div>
        </div>
        <div class="col">
            <div class="section-card h-100">
                <img src="https://images.unsplash.com/photo-1551836022-d5d88e9218df?auto=format&fit=crop&w=800&q=80" alt="Projeto Jovens" class="img-fluid rounded mb-3" />
                <h3>Projeto Jovens</h3>
                <p class="text-secondary">Encontros, discipulado e atividades de formação para a próxima geração.</p>
                <a href="#missao2" class="btn btn-secondary mt-2">Ler relato</a>
            </div>
        </div>
        <div class="col">
            <div class="section-card h-100">
                <img src="https://images.unsplash.com/photo-1493810329807-5cc9976ea6fb?auto=format&fit=crop&w=800&q=80" alt="Missão Educacional" class="img-fluid rounded mb-3" />
                <h3>Missão Educacional</h3>
                <p class="text-secondary">Oficinas de leitura e capacitação para famílias em situação de vulnerabilidade.</p>
                <a href="#missao3" class="btn btn-secondary mt-2">Ler relato</a>
            </div>
        </div>
    </div>

    <div id="missao1" class="section-card mt-5">
        <h3><i class="fas fa-map-marker-alt me-2 text-gold"></i>Comunidade Esperança</h3>
        <p class="text-secondary">A equipe visitou famílias locais e entregou cestas básicas. Maria relata a alegria de ver vidas restauradas e o impacto espiritual do acompanhamento semanal da Igreja.</p>
    </div>
    <div id="missao2" class="section-card mt-4">
        <h3><i class="fas fa-users me-2 text-gold"></i>Projeto Jovens</h3>
        <p class="text-secondary">Nosso grupo de jovens realizou estudos bíblicos e atividades de arte. Lucas descreve como o projeto trouxe unidade e inspiração para a próxima geração da comunidade.</p>
    </div>
    <div id="missao3" class="section-card mt-4">
        <h3><i class="fas fa-book-open me-2 text-gold"></i>Missão Educacional</h3>
        <p class="text-secondary">Foram oferecidas oficinas de leitura e capacitação. Ana compartilha como a iniciativa tem transformado famílias e ampliado oportunidades reais na região.</p>
    </div>

    <div class="section-card mt-4 text-center">
        <h3>Quero participar das missões</h3>
        <p class="text-secondary">Junte-se a nós no campo missionário. Entre em contato e saiba como fazer parte.</p>
        <a href="/Napalavra" class="btn btn-primary btn-lg mt-2">
            <i class="fas fa-globe me-2"></i> Falar com a equipe
        </a>
    </div>
</div>

