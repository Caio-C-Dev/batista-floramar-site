@{
    Layout = "_Layout";
    ViewBag.Title = "Planeje sua Visita | Igreja Batista Floramar BH";
    ViewBag.FullWidth = true;
}

<script type="application/ld+json">
{
  "@@context": "https://schema.org",
  "@@type": "WebPage",
  "name": "Planeje sua Visita – Comunidade Batista Floramar",
  "description": "Planeje sua visita à Comunidade Batista Floramar em Floramar, Belo Horizonte. Saiba o que esperar, horários de culto, como chegar e muito mais.",
  "url": "https://www.batistafloramar.com.br/Visita",
  "breadcrumb": {
    "@@type": "BreadcrumbList",
    "itemListElement": [
      { "@@type": "ListItem", "position": 1, "name": "Início", "item": "https://www.batistafloramar.com.br/" },
      { "@@type": "ListItem", "position": 2, "name": "Planejar Visita", "item": "https://www.batistafloramar.com.br/Visita" }
    ]
  },
  "isPartOf": { "@@id": "https://www.batistafloramar.com.br/#church" }
}
</script>
<style>
    .visita-hero {
        background: linear-gradient(135deg, #0d1b2a 0%, #12243a 100%);
        padding: 5.5rem 0 4rem;
        text-align: center;
        border-bottom: 1px solid rgba(212,175,55,.15);
        position: relative;
        overflow: hidden;
    }
    .visita-hero::before {
        content: '';
        position: absolute; inset: 0;
        background: radial-gradient(ellipse 60% 50% at 50% 100%, rgba(212,175,55,.07) 0%, transparent 70%);
    }
    .visita-hero h1 { font-size: clamp(2rem,5vw,3.2rem); font-weight: 800; color: #fff; margin-bottom: 1rem; position: relative; }
    .visita-hero p { color: #9aacb8; max-width: 620px; margin: 0 auto; font-size: 1.1rem; position: relative; }

    .visita-section { padding: 4.5rem 0; }
    .visita-section:nth-child(even) { background: var(--bg-secondary, #111e30); }

    .visita-card {
        background: var(--card-bg, #1a2844);
        border: 1px solid rgba(212,175,55,.15);
        border-radius: 18px;
        padding: 2rem;
        text-align: center;
        transition: transform .25s, box-shadow .25s;
        height: 100%;
    }
    .visita-card:hover { transform: translateY(-4px); box-shadow: 0 10px 30px rgba(0,0,0,.35); }
    .visita-card-icon { font-size: 2.2rem; color: var(--brand-gold, #d4af37); margin-bottom: 1rem; }
    .visita-card h4 { color: #fff; font-weight: 700; margin-bottom: .5rem; font-size: 1.05rem; }
    .visita-card p { color: #9aacb8; font-size: .9rem; margin: 0; }

    .horario-pill {
        display: inline-flex;
        align-items: center;
        gap: .6rem;
        background: rgba(212,175,55,.1);
        border: 1px solid rgba(212,175,55,.3);
        border-radius: 30px;
        padding: .6rem 1.4rem;
        color: #d4af37;
        font-weight: 600;
        font-size: .95rem;
        margin: .4rem;
    }
    .passo-item {
        display: flex;
        gap: 1.25rem;
        align-items: flex-start;
        margin-bottom: 1.75rem;
    }
    .passo-num {
        flex-shrink: 0;
        width: 42px; height: 42px;
        border-radius: 50%;
        background: var(--brand-gold, #d4af37);
        color: #0d1b2a;
        font-weight: 800;
        font-size: 1.05rem;
        display: flex; align-items: center; justify-content: center;
    }
    .passo-text h5 { color: #fff; font-weight: 700; margin-bottom: .25rem; font-size: 1rem; }
    .passo-text p { color: #9aacb8; font-size: .9rem; margin: 0; }

    .vestimenta-box {
        background: rgba(212,175,55,.06);
        border: 1px dashed rgba(212,175,55,.3);
        border-radius: 16px;
        padding: 2rem;
        text-align: center;
        max-width: 640px;
        margin: 0 auto;
    }
    .vestimenta-box i { font-size: 2.8rem; color: var(--brand-gold, #d4af37); margin-bottom: 1rem; display: block; }
    .vestimenta-box h3 { color: #fff; font-size: 1.3rem; margin-bottom: .75rem; }
    .vestimenta-box p { color: #c8d8e4; font-size: 1rem; margin: 0; }

    .cta-block {
        background: linear-gradient(135deg, #1a2844 0%, #12243a 100%);
        border-top: 1px solid rgba(212,175,55,.15);
        padding: 4rem 0;
        text-align: center;
    }
    .cta-block h2 { color: #fff; font-weight: 700; font-size: clamp(1.5rem,3vw,2rem); margin-bottom: .75rem; }
    .cta-block p { color: #9aacb8; max-width: 540px; margin: 0 auto 2rem; }
</style>

<!-- Hero -->
<div class="visita-hero scroll-reveal">
    <div class="container">
        <span class="section-eyebrow">Primeira vez aqui?</span>
        <h1>Planeje sua Visita</h1>
        <p>Sabemos que dar o primeiro passo pode ser desafiador. Estamos aqui para tornar isso simples e acolhedor para você e sua família.</p>
    </div>
</div>

<!-- O que esperar -->
<div class="visita-section">
    <div class="container">
        <div class="text-center mb-5 scroll-reveal">
            <span class="section-eyebrow">Ambiente</span>
            <h2 class="section-heading">O que você vai encontrar</h2>
            <p style="color:#9aacb8;max-width:560px;margin:0 auto;">Prepare-se para uma experiência acolhedora, com pessoas reais e uma mensagem transformadora.</p>
        </div>
        <div class="row g-4">
            <div class="col-sm-6 col-lg-3">
                <div class="visita-card scroll-reveal delay-1">
                    <div class="visita-card-icon"><i class="fas fa-hand-holding-heart"></i></div>
                    <h4>Ambiente Acolhedor</h4>
                    <p>Desde a recepção até o final do culto, você será tratado como parte da família.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="visita-card scroll-reveal delay-2">
                    <div class="visita-card-icon"><i class="fas fa-book-open"></i></div>
                    <h4>Palavra Bíblica</h4>
                    <p>Mensagens expositivas direto da Bíblia, práticas e relevantes para a vida de hoje.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="visita-card scroll-reveal delay-3">
                    <div class="visita-card-icon"><i class="fas fa-music"></i></div>
                    <h4>Louvor Vibrante</h4>
                    <p>Música de adoração que conduz o coração à presença de Deus.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="visita-card scroll-reveal delay-4">
                    <div class="visita-card-icon"><i class="fas fa-child"></i></div>
                    <h4>Espaço para Crianças</h4>
                    <p>Sua família toda é bem-vinda. Crianças e jovens têm lugar especial aqui.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Horários -->
<div class="visita-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 scroll-reveal">
                <span class="section-eyebrow">Quando nos reunimos</span>
                <h2 class="section-heading mb-4">Horários de Culto</h2>
                <div class="mb-2">
                    <span class="horario-pill"><i class="fas fa-sun"></i> Domingo · 10h00</span>
                    <span class="horario-pill"><i class="fas fa-moon"></i> Domingo · 18h00</span>
                    <span class="horario-pill"><i class="fas fa-star"></i> Quarta-feira · 20h00</span>
                </div>
                <p class="mt-3" style="color:#9aacb8;">As portas abrem 20 minutos antes de cada culto. Chegue cedo para conhecer as pessoas!</p>
            </div>
            <div class="col-lg-6 scroll-reveal delay-1">
                <div style="background:var(--card-bg,#1a2844);border:1px solid rgba(212,175,55,.15);border-radius:18px;padding:2rem;">
                    <h4 style="color:#fff;margin-bottom:1.5rem;font-size:1.1rem;"><i class="fas fa-map-marker-alt me-2" style="color:#d4af37;"></i>Como Chegar</h4>
                    <p style="color:#c8d8e4;margin-bottom:1rem;">
                        <strong style="color:#fff;">Rua José Lima de Almeida, 59</strong><br>
                        Floramar, Belo Horizonte – MG, 31710-140
                    </p>
                    <iframe
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3751.3!2d-43.9502!3d-19.8423!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sRua+Jos%C3%A9+Lima+de+Almeida%2C+59%2C+Floramar%2C+Belo+Horizonte!5e0!3m2!1spt!2sbr!4v1"
                        width="100%" height="200"
                        style="border:0;border-radius:12px;display:block;margin-bottom:.75rem;filter:brightness(.9);"
                        allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
                        title="Mapa Comunidade Batista Floramar">
                    </iframe>
                    <a href="https://www.google.com/maps/dir/?api=1&destination=Rua+Jos%C3%A9+Lima+de+Almeida,+59,+Floramar,+Belo+Horizonte,+MG"
                       target="_blank" rel="noopener noreferrer" class="btn btn-primary w-100">
                        <i class="fas fa-route me-2"></i> Abrir Rota no Google Maps
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Passos práticos -->
<div class="visita-section">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-5 scroll-reveal">
                <span class="section-eyebrow">Simples assim</span>
                <h2 class="section-heading mb-4">Sua primeira visita<br>em 3 passos</h2>
                <div>
                    <div class="passo-item">
                        <div class="passo-num">1</div>
                        <div class="passo-text">
                            <h5>Escolha o culto</h5>
                            <p>Domingo de manhã (10h), domingo à noite (18h) ou quarta-feira (20h). Todos são ótimos para uma primeira visita!</p>
                        </div>
                    </div>
                    <div class="passo-item">
                        <div class="passo-num">2</div>
                        <div class="passo-text">
                            <h5>Chegue com antecedência</h5>
                            <p>Chegar 10 a 15 minutos antes te dará tempo para conhecer alguém e se acomodar com calma.</p>
                        </div>
                    </div>
                    <div class="passo-item">
                        <div class="passo-num">3</div>
                        <div class="passo-text">
                            <h5>Seja você mesmo</h5>
                            <p>Não há expectativa de perfeição. Venha como você está; a Palavra de Deus faz o resto.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-7 scroll-reveal delay-1">
                <div class="vestimenta-box">
                    <i class="fas fa-tshirt"></i>
                    <h3>E sobre a roupa?</h3>
                    <p>Aqui você pode vir como se sentir mais confortável. Não exigimos traje específico. O que importa é que você esteja presente — Deus enxerga o coração, não a roupa.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Sobre a Igreja -->
<div class="visita-section">
    <div class="container">
        <div class="text-center mb-5 scroll-reveal">
            <span class="section-eyebrow">Quem somos</span>
            <h2 class="section-heading">Uma comunidade de fé</h2>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-sm-6 col-lg-4">
                <div class="visita-card scroll-reveal delay-1">
                    <div class="visita-card-icon"><i class="fas fa-bible"></i></div>
                    <h4>Igreja Bíblica</h4>
                    <p>Toda a nossa fé e prática são fundamentadas na Palavra de Deus, exposta com fidelidade e amor.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4">
                <div class="visita-card scroll-reveal delay-2">
                    <div class="visita-card-icon"><i class="fas fa-heart"></i></div>
                    <h4>Comunidade Ativa</h4>
                    <p>Somos uma família de fé com células, ministérios e ações que transformam vidas em Belo Horizonte.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4">
                <div class="visita-card scroll-reveal delay-3">
                    <div class="visita-card-icon"><i class="fas fa-praying-hands"></i></div>
                    <h4>Fé e Esperança</h4>
                    <p>Acreditamos num Deus que transforma vidas. Venha descobrir isso na prática aqui no Floramar.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- CTA Final -->
<div class="cta-block">
    <div class="container">
        <h2>Pronto para dar o primeiro passo?</h2>
        <p>Estamos ansiosos para te receber. Se tiver qualquer dúvida, é só nos chamar!</p>
        <div class="d-flex flex-wrap justify-content-center gap-3">
            <a href="https://www.google.com/maps/dir/?api=1&destination=Rua+Jos%C3%A9+Lima+de+Almeida,+59,+Floramar,+Belo+Horizonte,+MG"
               target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg">
                <i class="fas fa-route me-2"></i> Ver Localização
            </a>
            <a href="https://wa.me/5531992898901?text=Olá!%20Gostaria%20de%20planejar%20minha%20visita%20à%20Comunidade%20Batista%20Floramar."
               target="_blank" rel="noopener noreferrer" class="btn btn-outline-hero btn-lg">
                <i class="fab fa-whatsapp me-2"></i> Falar no WhatsApp
            </a>
        </div>
    </div>
</div>
