@using BatistaFloramar.Domain.Entities
@model Produto
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Editar Produto";
    ViewBag.AdminSection = "loja";
}

@section TopbarActions {
    <a href="@Url.Action("Index")" class="btn-admin-outline">
        <i class="fas fa-arrow-left"></i> Voltar
    </a>
}

<div class="admin-card" style="max-width: 780px;">
    <form method="post" asp-action="Edit" asp-route-id="@Model.Id" enctype="multipart/form-data" class="admin-form">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Slug" />
        <input type="hidden" asp-for="CriadoEm" />
        <div class="row g-3">
            <div class="col-md-8">
                <label asp-for="Nome">Nome do produto</label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="field-validation-error"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Preco">Preço (R$)</label>
                <input asp-for="Preco" type="number" step="0.01" min="0" class="form-control" />
                <span asp-validation-for="Preco" class="field-validation-error"></span>
            </div>
            <div class="col-12">
                <label asp-for="Descricao">Descrição</label>
                <textarea asp-for="Descricao" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Descricao" class="field-validation-error"></span>
            </div>
            <div class="col-12">
                @if (!string.IsNullOrEmpty(Model.Imagem))
                {
                    <div class="mb-2">
                        <span style="color:var(--admin-text-muted);font-size:.85rem;">Imagem atual:</span><br />
                        <img src="@Model.Imagem" alt="@Model.Nome" style="max-width:220px;max-height:220px;border-radius:8px;margin-top:.4rem;" />
                    </div>
                }
                <label for="imagemArquivo">Substituir imagem (opcional)</label>
                <input type="file" id="imagemArquivo" name="imagemArquivo" accept=".jpg,.jpeg,.png,.webp" class="form-control" />
                <span class="text-muted" style="font-size:.8rem">JPG, PNG ou WEBP. Máximo 5 MB.</span>
            </div>
            <div class="col-md-4">
                <label asp-for="Ordem">Ordem</label>
                <input asp-for="Ordem" type="number" class="form-control" min="0" />
            </div>
            <div class="col-md-8 d-flex align-items-end">
                <div class="form-check">
                    <input asp-for="Ativo" class="form-check-input" type="checkbox" />
                    <label asp-for="Ativo" class="form-check-label" style="text-transform:none; font-size: 0.9rem; color: var(--admin-text);">
                        Produto ativo (visível na loja)
                    </label>
                </div>
            </div>
            <div class="col-12 pt-2">
                <button type="submit" class="btn-admin">
                    <i class="fas fa-save"></i> Salvar Alterações
                </button>
            </div>
        </div>
    </form>
</div>
