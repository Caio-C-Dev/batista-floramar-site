@model BatistaFloramar.Models.CriarUsuarioViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Novo Usuário";
    ViewBag.AdminSection = "usuarios";
}

<div class="admin-card" style="max-width:480px">
    <form method="post" asp-action="Criar">
        @Html.AntiForgeryToken()
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert-admin-error mb-3">
                <i class="fas fa-exclamation-circle me-2"></i>
                @foreach (var erro in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@erro.ErrorMessage</div>
                }
            </div>
        }
        <div class="mb-3">
            <label asp-for="Usuario" class="form-label"></label>
            <input asp-for="Usuario" class="form-control" autocomplete="username" />
            <span asp-validation-for="Usuario" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Senha" class="form-label"></label>
            <input asp-for="Senha" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="Senha" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="ConfirmarSenha" class="form-label"></label>
            <input asp-for="ConfirmarSenha" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="ConfirmarSenha" class="text-danger small"></span>
        </div>
        <div class="mb-4">
            <label asp-for="Role" class="form-label"></label>
            <select asp-for="Role" class="form-select">
                <option value="Admin">Admin (acesso total)</option>
            </select>
            <span asp-validation-for="Role" class="text-danger small"></span>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn-admin">
                <i class="fas fa-save"></i> Criar Usuário
            </button>
            <a href="@Url.Action("Index")" class="btn-admin-outline">Cancelar</a>
        </div>
    </form>
</div>


