@using BatistaFloramar.Domain.Entities
@model IEnumerable<PodcastVideo>
@{
    ViewBag.Title = "Podcast | Comunidade Batista Floramar BH";
    Layout = "_Layout";
    ViewBag.FullWidth = true;
}
<style>
    .podcast-hero {
        background: radial-gradient(ellipse at top, var(--bg-tertiary) 0%, var(--bg-primary) 60%);
        padding: 5.5rem 0 4rem;
        text-align: center;
        border-bottom: 1px solid var(--brand-gold-border);
        position: relative;
        overflow: hidden;
    }
    .podcast-hero::before {
        content: '';
        position: absolute; inset: 0;
        background: radial-gradient(ellipse 60% 50% at 50% 100%, var(--brand-gold-light) 0%, transparent 70%);
    }
    .podcast-hero h1 { font-size: clamp(2rem,5vw,3.2rem); font-weight: 800; color: var(--text-primary); margin-bottom: 1rem; position: relative; }
    .podcast-hero .section-eyebrow { position: relative; }
    .podcast-hero p { color: var(--text-secondary); max-width: 620px; margin: 0 auto; font-size: 1.1rem; position: relative; }

    .podcast-section { padding: 4.5rem 0; }

    .cta-block {
        background: var(--bg-secondary);
        border-top: 1px solid var(--brand-gold-border);
        padding: 5rem 0;
        text-align: center;
    }
    .cta-block h2 { color: var(--text-primary); font-weight: 700; font-size: clamp(1.5rem,3vw,2rem); margin-bottom: .75rem; }
    .cta-block p { color: var(--text-secondary); max-width: 540px; margin: 0 auto 2rem; }
</style>

<!-- Hero -->
<div class="podcast-hero">
    <div class="container">
        <span class="section-eyebrow">Mensagens em Áudio e Vídeo</span>
        <h1>Podcast</h1>
        <p>Assista e ouça os podcasts com mensagens inspiradoras e reflexões Bíblicas dos pastores Rodrigo N. Ferreira e Delmo Gonçalves da Comunidade Batista Floramar.</p>
    </div>
</div>

<!-- Vídeos -->
<div class="podcast-section">
    <div class="container">
        @if (!Model.Any())
        {
            <div class="text-center py-5 scroll-reveal">
                <p class="text-secondary">Nenhum vídeo disponível no momento.</p>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 g-4">
                @foreach (var video in Model)
                {
                    <div class="col scroll-reveal">
                        <div class="video-card h-100">
                            <div class="ratio ratio-16x9 mb-3 rounded overflow-hidden">
                                <iframe src="@video.EmbedUrl"
                                        title="@video.Titulo"
                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                        allowfullscreen></iframe>
                            </div>
                            <h3>@video.Titulo</h3>
                            @if (!string.IsNullOrEmpty(video.Descricao))
                            {
                                <p class="text-secondary">@video.Descricao</p>
                            }
                            <a class="btn btn-secondary" href="@video.WatchUrl" target="_blank" rel="noopener noreferrer">
                                <i class="fab fa-youtube me-2"></i>Assistir no YouTube
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- CTA -->
<div class="cta-block">
    <div class="container">
        <h2>Tem uma pergunta para o Pastor?</h2>
        <p>Envie sua mensagem, pedido de oração ou dúvida. Nossa equipe cuidará do encaminhamento.</p>
        <a href="/Napalavra" class="btn btn-primary btn-lg">
            <i class="fas fa-comment-dots me-2"></i> Enviar Mensagem ao Pastor
        </a>
    </div>
</div>
