@using BatistaFloramar.Domain.Entities
@{
    var ministerios = ViewBag.Ministerios as IEnumerable<Ministerio>;
    var items = ministerios?.Where(m => m.Ativo).OrderBy(m => m.Ordem).ToList()
                ?? new List<Ministerio> {
                    new() { Nome="Jovens e Adolescentes", Icone="fas fa-bolt", Slug="jovens", ResumoBreve="Culto de Jovens e Adolescentes e acoes de impacto para a juventude." },
                    new() { Nome="Kids",      Icone="fas fa-child",  Slug="kids",     ResumoBreve="Cuidando das criancas com amor e carinho." },
                    new() { Nome="Louvor",    Icone="fas fa-music",  Slug="louvor",   ResumoBreve="Adoracao e musica para glorificar a Deus." },
                    new() { Nome="Batismo",   Icone="fas fa-water",  Slug="batismo",  ResumoBreve="Celebrando o passo publico da fe." },
                    new() { Nome="Casais",    Icone="fas fa-heart",  Slug="casais",   ResumoBreve="Fortalecendo familias com a Palavra." },
                    new() { Nome="Missoes",   Icone="fas fa-globe",  Slug="missoes",  ResumoBreve="Levando o evangelho alem das fronteiras." },
                };
}

<section class="page-section" id="ministerios" style="overflow:hidden;">
    <div class="container">
        <div class="text-center mb-5 scroll-reveal">
            <span class="section-eyebrow">Minist&eacute;rios</span>
            <h2 class="section-heading">Sirva com seus dons</h2>
            <p class="text-secondary" style="max-width:540px;margin:0 auto;">Conhe&ccedil;a cada minist&eacute;rio e descubra onde voc&ecirc; pode servir e florescer.</p>
        </div>
    </div>

    <div class="min-carousel-root">
        <div class="min-carousel-track" id="minTrack">
            @foreach (var m in items)
            {
                var resumo = !string.IsNullOrEmpty(m.ResumoBreve) ? m.ResumoBreve
                             : m.Descricao?.Length > 0 ? m.Descricao : "";
                var desc = resumo.Length > 60 ? resumo.Substring(0, 60) + "..." : resumo;
                <div class="min-carousel-slide">
                    <div class="min-card">
                        <div class="min-card-icon"><i class="@m.Icone"></i></div>
                        <h3 class="min-card-title h5">@m.Nome</h3>
                        <p class="min-card-desc">@desc</p>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="min-carousel-dots" id="minDots" aria-label="Navegacao"></div>

    <div class="text-center mt-5">
        <a href="/Ministerios" class="btn btn-outline-gold">
            <i class="fas fa-hands-praying me-2"></i>Ver todos os minist&eacute;rios
        </a>
    </div>
</section>

<style>
    .min-carousel-root {
        position: relative;
        width: 100%;
        padding: 0;
        box-sizing: border-box;
        -webkit-mask-image: linear-gradient(to right, transparent 0, black 80px, black calc(100% - 80px), transparent 100%);
        mask-image: linear-gradient(to right, transparent 0, black 80px, black calc(100% - 80px), transparent 100%);
    }
    .min-carousel-track {
        display: flex;
        gap: 4px;
        overflow-x: hidden;
        padding: 0.75rem 0.5rem 1.25rem;
    }
    .min-carousel-slide { flex: 0 0 175px; }
    .min-card {
        width: 175px; height: 175px;
        background: #141418;
        border: 1px solid rgba(230,193,90,0.10);
        border-radius: 16px;
        padding: 1.1rem 0.9rem;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        text-align: center; gap: 0.5rem;
        transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
        cursor: default; box-sizing: border-box;
    }
    .min-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5), 0 0 0 1px rgba(230,193,90,0.22);
        border-color: rgba(230,193,90,0.28);
    }
    .min-card-icon {
        width: 44px; height: 44px; border-radius: 12px;
        background: rgba(230,193,90,0.10);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.15rem; color: #E6C15A; flex-shrink: 0;
        transition: background 0.22s ease;
    }
    .min-card:hover .min-card-icon { background: rgba(230,193,90,0.20); }
    .min-card-title { color: #fff; font-size: 0.92rem; font-weight: 700; margin: 0; line-height: 1.2; }
    .min-card-desc {
        color: #9ca3af; font-size: 0.75rem; line-height: 1.4; margin: 0;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .min-carousel-dots { display: flex; justify-content: center; gap: 6px; margin-top: 0.5rem; }
    .min-dot {
        width: 7px; height: 7px; border-radius: 50%;
        background: rgba(255,255,255,0.18); border: none; padding: 0; cursor: pointer;
        transition: background 0.2s ease, transform 0.2s ease;
        position: relative;
    }
    .min-dot::after {
        content: ''; position: absolute; inset: -20px;
    }
    .min-dot.active { background: #E6C15A; transform: scale(1.35); }
    @@media (max-width: 767px) {
        .min-carousel-slide { flex: 0 0 150px; }
        .min-card { width: 150px; height: 150px; }
    }
    @@media (max-width: 479px) {
        .min-carousel-slide { flex: 0 0 135px; }
        .min-card { width: 135px; height: 135px; }
    }
</style>

<script>
(function () {
    var track  = document.getElementById('minTrack');
    var dotsEl = document.getElementById('minDots');
    if (!track) return;

    var origSlides = Array.from(track.querySelectorAll('.min-carousel-slide'));
    var N = origSlides.length;
    if (N === 0) return;

    /* Clone infinite loop: [N before][N real][N after] */
    origSlides.forEach(function(s) {
        var c = s.cloneNode(true); c.dataset.clone = 'after'; track.appendChild(c);
    });
    origSlides.slice().reverse().forEach(function(s) {
        var c = s.cloneNode(true); c.dataset.clone = 'before'; track.prepend(c);
    });

    function step() {
        var s = track.querySelector('.min-carousel-slide');
        var g = parseFloat(getComputedStyle(track).gap) || 4;
        return s ? s.offsetWidth + g : 179;
    }
    function cardW() {
        var s = track.querySelector('.min-carousel-slide');
        return s ? s.offsetWidth : 175;
    }
    function scrollForCenter(absIdx) {
        return absIdx * step() - (track.clientWidth - cardW()) / 2;
    }
    function centeredIdx() {
        return Math.round((track.scrollLeft + (track.clientWidth - cardW()) / 2) / step());
    }
    function realIdx() { return ((centeredIdx() - N) % N + N) % N; }
    function wrapIfNeeded() {
        var ci = centeredIdx();
        if (ci >= N * 2) track.scrollLeft -= N * step();
        else if (ci < N) track.scrollLeft += N * step();
    }

    /* Dots */
    var dotsArr = [];
    function buildDots() {
        dotsEl.innerHTML = ''; dotsArr = [];
        for (var i = 0; i < N; i++) {
            var d = document.createElement('button');
            d.className = 'min-dot';
            d.setAttribute('aria-label', 'Ministerio ' + (i + 1));
            (function(idx) { d.addEventListener('click', function() { snapTo(N + idx); }); })(i);
            dotsEl.appendChild(d); dotsArr.push(d);
        }
    }
    function updateDots() {
        var ri = realIdx();
        dotsArr.forEach(function(d, i) { d.classList.toggle('active', i === ri); });
    }
    track.addEventListener('scroll', function() { wrapIfNeeded(); updateDots(); }, { passive: true });

    /* Snap */
    var snapRaf = null;
    function snapTo(absIdx) {
        stopAuto();
        var target = scrollForCenter(absIdx);
        var start  = track.scrollLeft;
        var dist   = target - start;
        if (Math.abs(dist) < 1) { updateDots(); return; }
        var t0 = performance.now(), dur = 320;
        if (snapRaf) cancelAnimationFrame(snapRaf);
        function frame(now) {
            var t = Math.min((now - t0) / dur, 1);
            var e = 1 - Math.pow(1 - t, 3);
            track.scrollLeft = start + dist * e;
            if (t < 1) { snapRaf = requestAnimationFrame(frame); }
            else { track.scrollLeft = target; snapRaf = null; wrapIfNeeded(); updateDots(); }
        }
        snapRaf = requestAnimationFrame(frame);
    }

    /* Continuous mouse-position scroll */
    var mouseX = null, autoRaf = null;
    function stopAuto() { if (autoRaf) { cancelAnimationFrame(autoRaf); autoRaf = null; } }

    function autoTick() {
        autoRaf = null;
        if (mouseX === null) return;
        if (snapRaf) { autoRaf = requestAnimationFrame(autoTick); return; }

        var rect   = track.getBoundingClientRect();
        var relX   = mouseX - rect.left;
        var center = rect.width / 2;
        var offset = relX - center;
        var half   = cardW() / 2;

        if (Math.abs(offset) < half) { snapTo(centeredIdx()); return; }

        var cardsAway = (Math.abs(offset) - half) / step();
        var speed = Math.min(35, 4.0 + cardsAway * 6.0);
        track.scrollLeft += offset > 0 ? speed : -speed;
        autoRaf = requestAnimationFrame(autoTick);
    }

    /* Listen on document so overlapping elements (floatNav) do not block */
    document.addEventListener('mousemove', function(e) {
        var rect = track.getBoundingClientRect();
        var inTrack = e.clientX >= rect.left && e.clientX <= rect.right &&
                      e.clientY >= rect.top  && e.clientY <= rect.bottom;
        if (inTrack) {
            mouseX = e.clientX;
            if (!autoRaf && !snapRaf) autoRaf = requestAnimationFrame(autoTick);
        } else if (mouseX !== null) {
            mouseX = null; stopAuto(); snapTo(centeredIdx());
        }
    });
    track.addEventListener('mouseleave', function() {
        mouseX = null; stopAuto(); snapTo(centeredIdx());
    });

    /* Touch drag: free movement, snap on release */
    var tx = 0, startScroll = 0, isDragging = false;
    track.addEventListener('touchstart', function(e) {
        tx = e.touches[0].clientX; startScroll = track.scrollLeft; isDragging = true; stopAuto();
    }, { passive: true });
    track.addEventListener('touchmove', function(e) {
        if (!isDragging) return;
        track.scrollLeft = startScroll + (tx - e.touches[0].clientX);
        wrapIfNeeded();
    }, { passive: true });
    track.addEventListener('touchend', function() { isDragging = false; snapTo(centeredIdx()); }, { passive: true });

    /* Keyboard */
    document.addEventListener('keydown', function(e) {
        var sec = document.getElementById('ministerios');
        if (!sec) return;
        var r = sec.getBoundingClientRect();
        if (r.top > innerHeight || r.bottom < 0) return;
        if (e.key === 'ArrowLeft')  snapTo(centeredIdx() - 1);
        if (e.key === 'ArrowRight') snapTo(centeredIdx() + 1);
    });

    buildDots();
    track.scrollLeft = scrollForCenter(N);
    updateDots();
    window.addEventListener('resize', function() {
        track.scrollLeft = scrollForCenter(N); updateDots();
    }, { passive: true });
})();
</script>