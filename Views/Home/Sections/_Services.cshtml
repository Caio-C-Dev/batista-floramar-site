<section class="page-section section-dark" id="cultos" style="position:relative;overflow:hidden;">
    <div id="services-light-rays" aria-hidden="true" style="position:absolute;inset:0;z-index:0;pointer-events:none;"></div>
    <div class="container" style="position:relative;z-index:1;">
        <div class="text-center mb-5 scroll-reveal">
            <span class="section-eyebrow">Conheça os Cultos</span>
            <h2 class="section-heading">Venha adorar conosco</h2>
        </div>
        <div class="row g-3 justify-content-center">
            <div class="col-6 col-md-4">
                <div class="service-time-card scroll-reveal delay-1">
                    <div class="service-time-icon">
                        <i class="fas fa-sun"></i>
                    </div>
                    <h4>Domingo — Manhã</h4>
                    <p class="service-hour">10 horas</p>
                    <p class="text-muted-section">Culto de adoração e aprofundamento na pregação expositiva</p>
                    <p class="text-muted-section small mb-0"><i class="fas fa-user me-1"></i>Pr. Rodrigo N. Ferreira</p>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="service-time-card" style="position:relative;">
                    <span class="badge-libras-card">
                        <i class="fas fa-hands"></i><span class="badge-libras-texto"> LIBRAS</span>
                    </span>
                    <div class="service-time-icon">
                        <i class="fas fa-moon"></i>
                    </div>
                    <h4>Domingo — Noite</h4>
                    <p class="service-hour">18 horas</p>
                    <p class="text-muted-section">Culto de adoração e aprofundamento na pregação expositiva</p>
                    <p class="text-muted-section small mb-0"><i class="fas fa-user me-1"></i>Pr. Rodrigo N. Ferreira</p>
                </div>
            </div>
            <div class="col-8 col-sm-6 col-md-4">
                <div class="service-time-card">
                    <div class="service-time-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h4>Quarta — Família</h4>
                    <p class="service-hour">20 horas</p>
                    <p class="text-muted-section">Culto de oração em família e pregação temática das Escrituras</p>
                    <p class="text-muted-section small mb-0"><i class="fas fa-user me-1"></i>Pr. Delmo Gonçalves e Pra. Dinéia</p>
                </div>
            </div>
        </div>

        <div class="libras-banner mt-5">
            <div class="libras-banner-icon">
                <i class="fas fa-hands"></i>
            </div>
            <div class="libras-banner-body">
                <strong class="libras-banner-title">Intérprete de Libras</strong>
                <p class="libras-banner-text">Todo culto de <strong>Domingo à Noite (18h)</strong> conta com intérprete de Libras — nossa igreja é um lugar de todos.</p>
            </div>
            <div class="libras-banner-badge">
                Inclusão
            </div>
        </div>
    </div>
</section>

<style>
    #cultos::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 140px;
        z-index: 2;
        pointer-events: none;
        background: linear-gradient(to top, var(--bg-secondary) 0%, transparent 100%);
    }

    .badge-libras-card {
        position: absolute;
        top: 14px;
        right: 14px;
        background: linear-gradient(135deg, #1a6e3c, #25a25a);
        color: #fff;
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .06em;
        padding: 4px 10px;
        border-radius: 20px;
        text-transform: uppercase;
    }

    .libras-banner {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        background: linear-gradient(135deg, rgba(26,110,60,.18), rgba(37,162,90,.1));
        border: 1px solid rgba(37,162,90,.35);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        flex-wrap: wrap;
    }

    .libras-banner-icon {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1a6e3c, #25a25a);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: #fff;
        flex-shrink: 0;
    }

    .libras-banner-body {
        flex: 1;
        min-width: 200px;
    }

    .libras-banner-title {
        display: block;
        font-size: 1.05rem;
        color: #fff;
        margin-bottom: .2rem;
    }

    .libras-banner-text {
        margin: 0;
        color: var(--text-muted, #aaa);
        font-size: .92rem;
        line-height: 1.5;
    }

    @@media (max-width: 575.98px) {
        .badge-libras-card {
            padding: 5px 7px;
            font-size: .65rem;
        }
        .badge-libras-texto {
            display: none;
        }
    }

    .libras-banner-badge {
        background: rgba(37,162,90,.25);
        color: #25a25a;
        border: 1px solid rgba(37,162,90,.4);
        border-radius: 20px;
        padding: 6px 18px;
        font-size: .78rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        white-space: nowrap;
    }
</style>

<script type="module">
    import { initLightRays } from '/js/lightRays.js';
    (function () {
        var el = document.getElementById('services-light-rays');
        if (!el) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        initLightRays(el, {
            raysOrigin:     'top-center',
            raysColor:      '#ffffff',
            raysSpeed:      1,
            lightSpread:    0.5,
            rayLength:      3,
            followMouse:    true,
            mouseInfluence: 0.1,
            noiseAmount:    0,
            distortion:     0,
            pulsating:      false,
            fadeDistance:   1,
            saturation:     1,
        });
    })();
</script>
