@using BatistaFloramar.Application.Services
@{
    var versiculo = ViewBag.Versiculo as BibleVerseDto;
    var texto = versiculo?.Texto ?? "Confie no Senhor de todo o seu coração e não se apoie em seu próprio entendimento.";
    var referencia = versiculo?.Referencia ?? "Provérbios 3:5 (NVI)";
    var textoCompleto = $"\"{texto}\" — {referencia}";
    var whatsappUrl = $"https://wa.me/?text={Uri.EscapeDataString(textoCompleto)}";
}
<section class="verse-section">
    <div class="container">
        <div class="verse-banner scroll-reveal">
            <div class="verse-icon"><i class="fas fa-book-open"></i></div>
            <p class="section-eyebrow mb-3">Versículo do Dia</p>
            <blockquote class="verse-quote" id="verseText">
                "@texto"
            </blockquote>
            <cite class="verse-cite" id="verseRef">— @referencia</cite>

            <div class="verse-actions mt-4">
                <button id="btnCopiarVersiculo" class="verse-action-btn" onclick="copiarVersiculo()" title="Copiar versículo">
                    <i class="fas fa-copy me-2"></i><span id="copyLabel">Copiar</span>
                </button>
                <button onclick="shareWhatsapp()" class="verse-action-btn verse-action-whatsapp" title="Compartilhar no WhatsApp">
                    <i class="fab fa-whatsapp me-2"></i>WhatsApp
                </button>
                <button id="btnShareImagem" class="verse-action-btn verse-action-image" onclick="compartilharImagemVersiculo()" title="Compartilhar como imagem">
                    <i class="fas fa-image me-2"></i><span id="imageLabel">Imagem</span>
                </button>
                <button id="btnShareVersiculo" class="verse-action-btn verse-action-share" onclick="shareVersiculo()" title="Compartilhar" style="display:none;">
                    <i class="fas fa-share-alt me-2"></i>Compartilhar
                </button>
            </div>

            <!-- Canvas oculto usado para gerar a imagem do versículo (dimensões setadas via JS) -->
            <canvas id="verseCanvas" style="display:none;"></canvas>

            <!-- Toast de feedback (sucesso/erro) -->
            <div id="verseToast" class="verse-toast" role="status" aria-live="polite">
                <i class="verse-toast-icon fas fa-circle-info"></i>
                <span class="verse-toast-msg"></span>
            </div>
        </div>
    </div>
</section>

<style>
    .verse-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem;
    }
    .verse-action-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.6rem 1.4rem;
        border-radius: 30px;
        border: 1px solid rgba(212,175,55,.45);
        background: transparent;
        color: var(--brand-gold, #d4af37);
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        touch-action: manipulation;
        -webkit-tap-highlight-color: rgba(212,175,55,.2);
        transition: background .2s, color .2s, transform .15s;
        text-decoration: none;
        /* garante área de toque mínima */
        min-height: 44px;
        min-width: 44px;
        position: relative;
        z-index: 1;
    }
    /* Ícones não bloqueiam o toque — evento passa para o botão pai */
    .verse-action-btn i {
        pointer-events: none;
    }
    .verse-action-btn:hover {
        background: var(--brand-gold, #d4af37);
        color: #0d1b2a;
        transform: translateY(-2px);
    }
    .verse-action-whatsapp {
        border-color: rgba(37,211,102,.5);
        color: #25d366;
    }
    .verse-action-whatsapp:hover {
        background: #25d366;
        color: #fff;
        border-color: #25d366;
    }
    .verse-action-share {
        border-color: rgba(100,160,255,.4);
        color: #64a0ff;
    }
    .verse-action-share:hover {
        background: #64a0ff;
        color: #fff;
    }
    .verse-action-image {
        border-color: rgba(180,140,255,.45);
        color: #b48cff;
    }
    .verse-action-image:hover {
        background: #b48cff;
        color: #1a0d2e;
        border-color: #b48cff;
    }
    #btnCopiarVersiculo.copied {
        background: #1a4a2a;
        color: #5d8;
        border-color: #5d8;
    }

    /* ── Toast personalizado padrão site ── */
    .verse-toast {
        position: fixed;
        left: 50%;
        bottom: 1.75rem;
        transform: translate(-50%, 1rem);
        display: inline-flex;
        align-items: center;
        gap: .65rem;
        padding: .8rem 1.4rem;
        max-width: 90vw;
        background: linear-gradient(135deg, #1a2540 0%, #0f1a30 100%);
        color: #f0e6c8;
        border: 1px solid rgba(212,175,55,.45);
        border-radius: 12px;
        box-shadow: 0 12px 32px rgba(0,0,0,.55), 0 0 18px rgba(212,175,55,.18);
        font-size: .92rem;
        font-weight: 500;
        z-index: 10000;
        opacity: 0;
        pointer-events: none;
        transition: opacity .28s ease, transform .28s ease;
    }
    .verse-toast.show {
        opacity: 1;
        transform: translate(-50%, 0);
    }
    .verse-toast.error {
        border-color: rgba(255,120,120,.55);
        box-shadow: 0 12px 32px rgba(0,0,0,.55), 0 0 18px rgba(255,120,120,.25);
        color: #ffd9d9;
    }
    .verse-toast.success {
        border-color: rgba(120,220,150,.55);
        color: #d6f5e0;
    }
    .verse-toast-icon {
        font-size: 1.1rem;
        color: var(--brand-gold, #d4af37);
    }
    .verse-toast.error .verse-toast-icon { color: #ff7d7d; }
    .verse-toast.success .verse-toast-icon { color: #6fdc8c; }
</style>

<script>
    (function () {
        // Mostrar botão nativo de share se disponível
        if (navigator.share) {
            document.getElementById('btnShareVersiculo').style.display = 'inline-flex';
        }
    })();

    /* Pré-carrega template assim que script roda (cache no browser).
       Sem isso, await dentro do click handler estoura o user gesture do navigator.share. */
    let _verseTemplate = null;
    (function _preloadTemplate() {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.onload = () => { _verseTemplate = img; };
        img.src = '/images/versiculo-template.jpg';
    })();

    /* Toast de feedback (padrão visual do site) */
    let _toastTimer = null;
    function mostrarToastVersiculo(msg, tipo) {
        const t = document.getElementById('verseToast');
        if (!t) return;
        const icon = t.querySelector('.verse-toast-icon');
        const span = t.querySelector('.verse-toast-msg');
        t.classList.remove('error', 'success');
        if (tipo === 'error') {
            t.classList.add('error');
            icon.className = 'verse-toast-icon fas fa-triangle-exclamation';
        } else if (tipo === 'success') {
            t.classList.add('success');
            icon.className = 'verse-toast-icon fas fa-circle-check';
        } else {
            icon.className = 'verse-toast-icon fas fa-circle-info';
        }
        span.textContent = msg;
        t.classList.add('show');
        if (_toastTimer) clearTimeout(_toastTimer);
        _toastTimer = setTimeout(() => t.classList.remove('show'), 3500);
    }

    function copiarVersiculo() {
        const texto = document.getElementById('verseText').innerText.replace(/\n/g, ' ').trim();
        const ref = document.getElementById('verseRef').innerText.trim();
        const full = texto + ' ' + ref;
        navigator.clipboard.writeText(full).then(() => {
            const btn = document.getElementById('btnCopiarVersiculo');
            const label = document.getElementById('copyLabel');
            btn.classList.add('copied');
            label.textContent = 'Copiado!';
            setTimeout(() => {
                btn.classList.remove('copied');
                label.textContent = 'Copiar';
            }, 2000);
        });
    }

    function shareWhatsapp() {
        const texto = document.getElementById('verseText').innerText.replace(/\n/g, ' ').trim();
        const ref = document.getElementById('verseRef').innerText.trim();
        const full = '"' + texto + '" \u2014 ' + ref;
        // window.location.href é a forma mais confiável de abrir o app no celular
        window.location.href = 'https://wa.me/?text=' + encodeURIComponent(full);
    }

    function shareVersiculo() {
        const texto = document.getElementById('verseText').innerText.replace(/\n/g, ' ').trim();
        const ref = document.getElementById('verseRef').innerText.trim();
        navigator.share({
            title: 'Versículo do Dia — Comunidade Batista Floramar',
            text: texto + ' ' + ref,
            url: window.location.href
        }).catch(() => {});
    }

    /* ─── Gerador de imagem do versículo (Canvas 1080x1080) ─── */
    function _loadImg(src) {
        return new Promise((resolve, reject) => {
            const img = new Image();
            img.crossOrigin = 'anonymous';
            img.onload = () => resolve(img);
            img.onerror = reject;
            img.src = src;
        });
    }

    function _wrapText(ctx, text, maxWidth) {
        const words = text.split(/\s+/);
        const lines = [];
        let line = '';
        for (let i = 0; i < words.length; i++) {
            const test = line ? line + ' ' + words[i] : words[i];
            if (ctx.measureText(test).width > maxWidth && line) {
                lines.push(line);
                line = words[i];
            } else {
                line = test;
            }
        }
        if (line) lines.push(line);
        return lines;
    }

    /* Caixa central (cream/dourada) na imagem template — coordenadas relativas (0-1)
       calibradas pela posição do quadro decorativo. Texto é renderizado dentro com padding. */
    const VERSE_BOX = {
        leftPct:   0.165,
        topPct:    0.305,
        rightPct:  0.835,
        bottomPct: 0.890,
        padPct:    0.045   // padding interno relativo à largura do canvas
    };

    function _gerarImagemVersiculoSync() {
        const canvas = document.getElementById('verseCanvas');
        const ctx = canvas.getContext('2d');

        const texto = document.getElementById('verseText').innerText.replace(/\n/g, ' ').replace(/^"|"$/g, '').trim();
        const ref = document.getElementById('verseRef').innerText.replace(/^—\s*/, '').trim();

        if (!_verseTemplate) {
            throw new Error('Template ainda carregando. Tente novamente em 1 segundo.');
        }
        const tpl = _verseTemplate;
        canvas.width = tpl.width;
        canvas.height = tpl.height;
        ctx.drawImage(tpl, 0, 0, tpl.width, tpl.height);

        const W = canvas.width, H = canvas.height;

        // Caixa central de texto
        const boxL = W * VERSE_BOX.leftPct;
        const boxT = H * VERSE_BOX.topPct;
        const boxR = W * VERSE_BOX.rightPct;
        const boxB = H * VERSE_BOX.bottomPct;
        const pad  = W * VERSE_BOX.padPct;
        const innerL = boxL + pad;
        const innerR = boxR - pad;
        const innerT = boxT + pad;
        const innerB = boxB - pad;
        const innerW = innerR - innerL;
        const innerH = innerB - innerT;
        const cx = (boxL + boxR) / 2;

        // Auto-fit: começa fonte grande, reduz até caber em altura
        ctx.fillStyle = '#1a2540';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';

        const refSize = Math.round(W * 0.026);   // referência ~3% width
        const refLineH = Math.round(refSize * 1.3);
        const gap = Math.round(refSize * 1.2);

        let fontSize = Math.round(W * 0.055);
        let lines, lineH, totalH;
        while (fontSize > 14) {
            ctx.font = '600 ' + fontSize + 'px Georgia, "Times New Roman", serif';
            lines = _wrapText(ctx, '"' + texto + '"', innerW);
            lineH = Math.round(fontSize * 1.25);
            totalH = lines.length * lineH + gap + refLineH;
            if (totalH <= innerH) break;
            fontSize -= 2;
        }

        // Centraliza verticalmente dentro da caixa
        let y = innerT + (innerH - totalH) / 2;

        ctx.font = '600 ' + fontSize + 'px Georgia, "Times New Roman", serif';
        ctx.fillStyle = '#1a2540';
        for (const ln of lines) {
            ctx.fillText(ln, cx, y);
            y += lineH;
        }

        // Referência (itálico dourado)
        y += gap;
        ctx.font = 'italic 600 ' + refSize + 'px Georgia, "Times New Roman", serif';
        ctx.fillStyle = '#a37a1c';
        ctx.fillText('— ' + ref, cx, y);

        return canvas;
    }

    function _canvasToBlob(canvas) {
        return new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.92));
    }

    async function compartilharImagemVersiculo() {
        const btn = document.getElementById('btnShareImagem');
        const lbl = document.getElementById('imageLabel');
        const original = lbl.textContent;

        try {
            // Renderiza canvas SYNC (template já pré-carregado) — preserva user gesture
            const canvas = _gerarImagemVersiculoSync();

            // toBlob é assíncrono mas curto — Chrome/Safari mantêm gesture nesse intervalo
            const blob = await _canvasToBlob(canvas);
            const file = new File([blob], 'versiculo-do-dia.jpg', { type: 'image/jpeg' });

            if (navigator.canShare && navigator.canShare({ files: [file] })) {
                await navigator.share({
                    files: [file],
                    title: 'Versículo do Dia',
                    text: 'Versículo do Dia — Comunidade Batista Floramar\nbatistafloramar.com.br'
                });
            } else {
                // Desktop sem Web Share files: download
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'versiculo-do-dia.jpg';
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
                mostrarToastVersiculo('Imagem baixada! Verifique sua pasta de downloads.', 'success');
            }
        } catch (e) {
            // AbortError = usuário fechou dialog de share — ignora silencioso
            if (e && e.name === 'AbortError') return;
            console.error('Erro imagem versículo:', e);

            let msg = 'Não foi possível gerar a imagem do versículo. Tente novamente.';
            if (e && e.message) {
                if (e.message.indexOf('Template') >= 0) {
                    msg = 'Aguarde um instante — a imagem ainda está carregando.';
                } else if (e.message.indexOf('user gesture') >= 0) {
                    msg = 'Toque no botão novamente para compartilhar.';
                }
            }
            mostrarToastVersiculo(msg, 'error');
        }
    }
</script>

