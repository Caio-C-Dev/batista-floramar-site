@using BatistaFloramar.Domain.Entities
@{
    var eventos = ViewBag.EventosSemanais as List<EventoSemanal>;
    bool temEventos = eventos != null && eventos.Count > 0;

    var diasOrdem = new[] { "Segunda", "Terça", "Quarta", "Quinta", "Sexta", "Sábado", "Domingo" };

    var agrupados = temEventos
        ? diasOrdem
            .Select(d => new { Dia = d, Items = eventos!.Where(e => e.DiaSemana == d).OrderBy(e => e.Ordem).ToList() })
            .Where(g => g.Items.Count > 0)
            .ToList()
        : null;
}

<section class="page-section" id="agenda-semanal" style="background-color:var(--bg-tertiary);">
    <div class="container">
        <div class="text-center mb-5 scroll-reveal">
            <span class="section-eyebrow">Agenda</span>
            <h2 class="section-heading">Programação Semanal</h2>
            <p class="text-muted-section mt-2">Venha participar da vida da nossa comunidade durante a semana.</p>
        </div>

        @if (temEventos && agrupados != null)
        {
            <div class="agenda-grid">
                @foreach (var grupo in agrupados)
                {
                    <div class="agenda-dia-card scroll-reveal">
                        <div class="agenda-dia-header">
                            <span class="agenda-dia-nome">@grupo.Dia</span>
                            <span class="agenda-dia-count">@grupo.Items.Count evento@(grupo.Items.Count > 1 ? "s" : "")</span>
                        </div>
                        <div class="agenda-dia-body">
                            @foreach (var ev in grupo.Items)
                            {
                                <div class="agenda-item">
                                    <span class="agenda-horario">@ev.Horario</span>
                                    <div class="agenda-info">
                                        <span class="agenda-titulo">@ev.Titulo</span>
                                        @if (!string.IsNullOrWhiteSpace(ev.Descricao))
                                        {
                                            <span class="agenda-desc">@ev.Descricao</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5 scroll-reveal">
                <i class="fas fa-calendar-week" style="font-size:2.5rem;color:#4a5a7a;margin-bottom:1rem;display:block;"></i>
                <p class="text-muted-section">Programação em breve. Fique ligado!</p>
            </div>
        }
    </div>
</section>

<style>
    /* ── Agenda Semanal Grid ── */
    .agenda-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
        gap: 1.25rem;
    }

    .agenda-dia-card {
        background: var(--bg-secondary);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        overflow: hidden;
        transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
        box-shadow: 0 4px 20px rgba(0, 0, 0, .28);
    }

    .agenda-dia-card:hover {
        transform: translateY(-4px);
        border-color: rgba(230, 193, 90, .35);
        box-shadow: 0 8px 32px rgba(0, 0, 0, .38);
    }

    .agenda-dia-header {
        background: linear-gradient(135deg, rgba(230, 193, 90, .18) 0%, rgba(230, 193, 90, .06) 100%);
        border-bottom: 1px solid rgba(230, 193, 90, .22);
        padding: .75rem 1.1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .agenda-dia-nome {
        color: var(--brand-gold);
        font-weight: 800;
        font-size: .95rem;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .agenda-dia-count {
        background: rgba(230, 193, 90, .14);
        color: var(--brand-gold);
        border: 1px solid rgba(230, 193, 90, .3);
        border-radius: 999px;
        padding: .1rem .55rem;
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .04em;
    }

    .agenda-dia-body {
        padding: .85rem 1.1rem 1.1rem;
        display: flex;
        flex-direction: column;
        gap: .75rem;
    }

    .agenda-item {
        display: flex;
        align-items: flex-start;
        gap: .75rem;
    }

    .agenda-horario {
        background: rgba(230, 193, 90, .1);
        color: var(--brand-gold);
        border: 1px solid rgba(230, 193, 90, .25);
        border-radius: 8px;
        padding: .25rem .55rem;
        font-size: .72rem;
        font-weight: 700;
        white-space: nowrap;
        letter-spacing: .03em;
        align-self: flex-start;
        flex-shrink: 0;
        margin-top: .1rem;
    }

    .agenda-info {
        display: flex;
        flex-direction: column;
        gap: .15rem;
        min-width: 0;
    }

    .agenda-titulo {
        color: var(--text-primary);
        font-weight: 700;
        font-size: .92rem;
        line-height: 1.35;
    }

    .agenda-desc {
        color: var(--text-secondary);
        font-size: .8rem;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* ── Mobile ── */
    @@media (max-width: 575.98px) {
        .agenda-grid {
            grid-template-columns: 1fr;
            gap: .85rem;
        }

        .agenda-dia-header {
            padding: .6rem .9rem;
        }

        .agenda-dia-body {
            padding: .7rem .9rem .9rem;
            gap: .6rem;
        }

        .agenda-horario {
            font-size: .68rem;
        }

        .agenda-titulo {
            font-size: .88rem;
        }

        .agenda-desc {
            font-size: .75rem;
        }
    }
</style>
