@using BatistaFloramar.Application.Services
@{
    var shorts = ViewBag.UltimosShorts as List<YouTubeVideo>;
}
@if (shorts != null && shorts.Count > 0)
{
    /* ── JSON-LD: VideoObject list para SEO ── */
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "ItemList",
      "name": "Últimos Shorts — Comunidade Batista Floramar",
      "description": "Shorts e vídeos recentes do canal no YouTube da Comunidade Batista Floramar.",
      "url": "https://www.youtube.com/@@comunidadebatistafloramar",
      "itemListElement": [
        @for (int i = 0; i < shorts.Count; i++)
        {
            var v = shorts[i];
            <text>
            {
              "@@type": "ListItem",
              "position": @(i + 1),
              "item": {
                "@@type": "VideoObject",
                "name": "@Html.Raw(v.Title?.Replace("\"", "\\\""))",
                "url": "https://www.youtube.com/shorts/@v.VideoId",
                "thumbnailUrl": "@v.ThumbnailUrl",
                "uploadDate": "@v.PublishedAt.ToString("yyyy-MM-dd")"
              }
            }@(i < shorts.Count - 1 ? "," : "")
            </text>
        }
      ]
    }
    </script>

    <section class="page-section py-5" id="shorts-rail"
             aria-label="Últimos vídeos do YouTube — Comunidade Batista Floramar"
             itemscope itemtype="https://schema.org/ItemList"
             data-channel-id="UCd5R5bNSpiIk2Swx2KWSxlQ">

        <!-- Decoração de fundo -->
        <div class="shorts-bg-deco" aria-hidden="true">
            <div class="shorts-bg-glow shorts-bg-glow--main"></div>
            <div class="shorts-bg-glow shorts-bg-glow--side"></div>
            <div class="shorts-bg-grid"></div>
        </div>

        <div class="container" style="position:relative;z-index:1">
            <header class="text-center mb-4 scroll-reveal">
                <span class="section-eyebrow shorts-eyebrow">
                    <span class="shorts-yt-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                        </svg>
                    </span>
                    Recentes no YouTube
                </span>
                <h2 class="shorts-cards-title section-heading">Acompanhe nossos vídeos</h2>
                <p class="shorts-cards-sub">Arraste para navegar pelos últimos Shorts.</p>
            </header>

            <div class="shorts-cards-viewport scroll-reveal" id="shortsCardsViewport">
                <div class="shorts-cards-track" id="shortsCardsTrack">
                    @for (int i = 0; i < shorts.Count; i++)
                    {
                        var v = shorts[i];
                        /* hqdefault sempre existe; maxresdefault como fallback de qualidade */
                        var portraitThumb = $"https://i.ytimg.com/vi/{v.VideoId}/hqdefault.jpg";
                        var maxresThumb   = $"https://i.ytimg.com/vi/{v.VideoId}/maxresdefault.jpg";
                        var hqThumb       = $"https://i.ytimg.com/vi/{v.VideoId}/mqdefault.jpg";
                        <div class="story-card-wrapper" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                            <meta itemprop="position" content="@(i+1)" />
                            <button type="button" class="story-card"
                                    data-index="@i"
                                    data-video-id="@v.VideoId"
                                    data-title="@v.Title"
                                    onclick="abrirShortModalCard(this, event)"
                                    aria-label="Assistir: @v.Title"
                                    itemprop="item" itemscope itemtype="https://schema.org/VideoObject">
                                <meta itemprop="name" content="@v.Title" />
                                <meta itemprop="url" content="https://www.youtube.com/shorts/@v.VideoId" />
                                <img src="@portraitThumb"
                                     alt="@v.Title"
                                     loading="lazy"
                                     draggable="false"
                                     itemprop="thumbnailUrl"
                                     onerror="this.onerror=null;this.src='@maxresThumb';this.onerror=function(){this.src='@hqThumb'}" />
                                <div class="story-card-grad"></div>
                                @if (v.IsShort)
                                {
                                    <span class="story-card-badge" aria-label="Shorts">
                                        <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                                        </svg>
                                        Shorts
                                    </span>
                                }
                                <div class="story-card-meta">
                                    <h3 class="story-card-title">@v.Title</h3>
                                </div>
                                <div class="story-card-play" aria-hidden="true">
                                    <i class="fas fa-play"></i>
                                </div>
                                <div class="story-card-shine" aria-hidden="true"></div>
                            </button>
                        </div>
                    }
                </div>
            </div>

            <div class="text-center mt-4 scroll-reveal">
                <a href="https://www.youtube.com/@@comunidadebatistafloramar"
                   target="_blank" rel="noopener noreferrer"
                   class="shorts-cards-cta"
                   aria-label="Ver mais vídeos no canal do YouTube da Comunidade Batista Floramar">
                    <span class="shorts-cards-cta-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                        </svg>
                    </span>
                    Ver mais no canal
                    <span class="shorts-cards-cta-arrow" aria-hidden="true">&rarr;</span>
                </a>
            </div>
        </div>

        <!-- Modal player Shorts (9:16) -->
        <div id="shortModal" class="short-modal" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="shortModalTitle">
            <button type="button" class="short-modal-close" aria-label="Fechar vídeo" onclick="fecharShortModal()">
                <i class="fas fa-times" aria-hidden="true"></i>
            </button>
            <button type="button" class="short-modal-nav prev" aria-label="Vídeo anterior" onclick="navegarShort(-1)">
                <i class="fas fa-chevron-left" aria-hidden="true"></i>
            </button>
            <div class="short-modal-frame">
                <div class="short-modal-iframe-wrap">
                    <iframe id="shortIframe" src="" frameborder="0"
                            allow="autoplay; encrypted-media; picture-in-picture; clipboard-write"
                            allowfullscreen
                            title="Reprodutor de vídeo"></iframe>
                </div>
                <div class="short-modal-meta">
                    <p class="short-modal-title" id="shortModalTitle"></p>
                    <a id="shortModalLink" href="#" target="_blank" rel="noopener noreferrer" class="short-modal-link">
                        Abrir no YouTube <i class="fas fa-arrow-up-right-from-square ms-1" aria-hidden="true"></i>
                    </a>
                </div>
            </div>
            <button type="button" class="short-modal-nav next" aria-label="Próximo vídeo" onclick="navegarShort(1)">
                <i class="fas fa-chevron-right" aria-hidden="true"></i>
            </button>
        </div>
    </section>

    <style>
        /* ── Background harmônico ── */
        #shorts-rail {
            background:
                linear-gradient(
                    to bottom,
                    var(--bg-primary, #0b0b0f) 0%,
                    #0d1118 40%,
                    #111827 70%,
                    var(--bg-secondary, #15151d) 100%
                );
            position: relative;
            overflow: hidden;
            isolation: isolate;
        }

        /* Decorações de fundo */
        .shorts-bg-deco {
            position: absolute;
            inset: 0;
            pointer-events: none;
            z-index: 0;
        }
        .shorts-bg-glow {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: .55;
        }
        .shorts-bg-glow--main {
            width: 600px;
            height: 340px;
            top: -60px;
            left: 50%;
            transform: translateX(-50%);
            background: radial-gradient(ellipse, rgba(212,175,55,.18) 0%, rgba(180,30,30,.12) 55%, transparent 80%);
        }
        .shorts-bg-glow--side {
            width: 380px;
            height: 280px;
            bottom: -40px;
            right: -80px;
            background: radial-gradient(ellipse, rgba(212,175,55,.09) 0%, transparent 70%);
        }
        .shorts-bg-grid {
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(212,175,55,.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(212,175,55,.04) 1px, transparent 1px);
            background-size: 48px 48px;
            mask-image: radial-gradient(ellipse 90% 70% at 50% 50%, black 20%, transparent 100%);
        }

        /* ── Eyebrow ── */
        .shorts-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            background: rgba(255,255,255,.06);
            border: 1px solid rgba(255,255,255,.1);
            border-radius: 999px;
            padding: .35rem 1rem .35rem .65rem;
            backdrop-filter: blur(6px);
        }
        .shorts-yt-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 24px;
            height: 24px;
            background: #ff0000;
            border-radius: 6px;
            color: #fff;
            flex-shrink: 0;
        }
        .shorts-yt-icon svg { width: 14px; height: 14px; }

        .shorts-cards-title {
            color: #fff;
            font-size: 2rem;
            font-weight: 700;
            margin: .5rem 0 .35rem;
        }
        .shorts-cards-sub {
            color: #7d8da0;
            font-size: .95rem;
            margin: 0;
        }

        /* ── Carrossel drag ── */
        .shorts-cards-viewport {
            overflow: hidden;
            cursor: grab;
            user-select: none;
            padding: .75rem 0 1.5rem;
            -webkit-mask-image: linear-gradient(to right, transparent 0, black 48px, black calc(100% - 48px), transparent 100%);
                    mask-image: linear-gradient(to right, transparent 0, black 48px, black calc(100% - 48px), transparent 100%);
        }
        .shorts-cards-viewport.dragging { cursor: grabbing; }

        .shorts-cards-track {
            display: flex;
            gap: 1.25rem;
            padding: .5rem 2rem 1rem;
            transform: translate3d(0, 0, 0);
            will-change: transform;
            transition: transform .35s cubic-bezier(.22,.61,.36,1);
        }
        .shorts-cards-viewport.dragging .shorts-cards-track { transition: none; }

        /* ── Cards ── */
        .story-card-wrapper { flex: 0 0 auto; }

        .story-card {
            position: relative;
            display: block;
            width: 200px;
            height: 356px;
            border-radius: 16px;
            overflow: hidden;
            background: #111;
            border: 1px solid rgba(255,255,255,.06);
            padding: 0;
            cursor: pointer;
            color: inherit;
            font: inherit;
            box-shadow:
                0 10px 30px rgba(0,0,0,.55),
                0 0 0 1px rgba(255,255,255,.04) inset;
            transition: transform .3s cubic-bezier(.22,.61,.36,1), box-shadow .3s ease, border-color .3s ease;
        }
        .story-card:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow:
                0 24px 48px rgba(0,0,0,.7),
                0 0 28px rgba(212,175,55,.2),
                0 0 0 1px rgba(212,175,55,.25) inset;
            border-color: rgba(212,175,55,.3);
        }

        .story-card img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: top center;
            transition: transform .6s cubic-bezier(.22,.61,.36,1);
            pointer-events: none;
        }
        .story-card:hover img { transform: scale(1.08); }

        .story-card-grad {
            position: absolute;
            inset: 0;
            background:
                linear-gradient(to top, rgba(0,0,0,.9) 0%, rgba(0,0,0,.35) 50%, transparent 75%),
                linear-gradient(to bottom, rgba(0,0,0,.4) 0%, transparent 30%);
            pointer-events: none;
        }

        /* Badge Shorts */
        .story-card-badge {
            position: absolute;
            top: 10px;
            left: 10px;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: #ff0000;
            color: #fff;
            font-size: .6rem;
            font-weight: 700;
            letter-spacing: .05em;
            padding: 4px 8px 4px 6px;
            border-radius: 6px;
            text-transform: uppercase;
            z-index: 2;
            box-shadow: 0 2px 8px rgba(255,0,0,.45);
        }
        .story-card-badge svg { width: 11px; height: 11px; }

        .story-card-meta {
            position: absolute;
            inset: auto 0 0 0;
            padding: 1.25rem 1rem 1rem;
            color: #fff;
            z-index: 2;
            pointer-events: none;
        }
        .story-card-title {
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: .01em;
            margin: 0;
            line-height: 1.3;
            text-shadow: 1px 2px 8px rgba(0,0,0,.9);
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        /* Botão play */
        .story-card-play {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(.75);
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: rgba(212,175,55,.95);
            color: #0a0a0a;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            opacity: 0;
            transition: opacity .25s ease, transform .25s ease;
            pointer-events: none;
            box-shadow:
                0 0 0 10px rgba(212,175,55,.15),
                0 4px 20px rgba(212,175,55,.5);
            z-index: 2;
        }
        .story-card:hover .story-card-play {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1);
        }

        /* Brilho no hover */
        .story-card-shine {
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,.12) 0%, transparent 50%);
            opacity: 0;
            transition: opacity .3s ease;
            pointer-events: none;
            z-index: 1;
            border-radius: inherit;
        }
        .story-card:hover .story-card-shine { opacity: 1; }

        /* CTA */
        .shorts-cards-cta {
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            color: #c8d8e8;
            font-weight: 600;
            text-decoration: none;
            font-size: .95rem;
            padding: .55rem 1.25rem;
            border: 1px solid rgba(255,255,255,.12);
            border-radius: 999px;
            background: rgba(255,255,255,.04);
            backdrop-filter: blur(6px);
            transition: color .25s, border-color .25s, background .25s, transform .25s;
        }
        .shorts-cards-cta:hover {
            color: var(--brand-gold, #d4af37);
            border-color: rgba(212,175,55,.4);
            background: rgba(212,175,55,.07);
            transform: translateY(-2px);
        }
        .shorts-cards-cta-icon {
            display: inline-flex;
            align-items: center;
            width: 18px;
            height: 18px;
            color: #ff3333;
            flex-shrink: 0;
        }
        .shorts-cards-cta-icon svg { width: 100%; height: 100%; }
        .shorts-cards-cta-arrow {
            display: inline-block;
            transition: transform .25s ease;
        }
        .shorts-cards-cta:hover .shorts-cards-cta-arrow { transform: translateX(4px); }

        /* Mobile */
        @@media (max-width: 575.98px) {
            .story-card { width: 168px; height: 300px; }
            .story-card-title { font-size: .9rem; }
            .shorts-cards-title { font-size: 1.6rem; }
        }

        /* ── Modal player ── */
        .short-modal {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.93);
            backdrop-filter: blur(12px);
            z-index: 9999;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }
        .short-modal.open {
            display: flex;
            animation: shortFadeIn .2s ease-out;
        }
        @@keyframes shortFadeIn {
            from { opacity: 0; transform: scale(.97); }
            to   { opacity: 1; transform: scale(1); }
        }

        .short-modal-frame {
            position: relative;
            display: flex;
            flex-direction: column;
            gap: .8rem;
            max-width: 100%;
            max-height: 100%;
            align-items: center;
        }

        .short-modal-iframe-wrap {
            position: relative;
            aspect-ratio: 9 / 16;
            height: min(85vh, 700px);
            max-width: 100%;
            border-radius: 20px;
            overflow: hidden;
            background: #000;
            box-shadow:
                0 24px 64px rgba(0,0,0,.7),
                0 0 0 1px rgba(212,175,55,.22);
        }
        .short-modal-iframe-wrap iframe {
            width: 100%;
            height: 100%;
            display: block;
            border: 0;
        }

        .short-modal-meta {
            text-align: center;
            color: #f0e6c8;
            max-width: 400px;
        }
        .short-modal-title {
            font-size: .9rem;
            font-weight: 600;
            margin: 0 0 .3rem;
            line-height: 1.4;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .short-modal-link {
            color: var(--brand-gold, #d4af37);
            font-size: .78rem;
            text-decoration: none;
            font-weight: 600;
        }
        .short-modal-link:hover { text-decoration: underline; }

        .short-modal-close {
            position: absolute;
            top: 1rem;
            right: 1rem;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: rgba(255,255,255,.08);
            color: #fff;
            border: 1px solid rgba(255,255,255,.15);
            cursor: pointer;
            font-size: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background .2s, transform .2s;
            z-index: 1;
        }
        .short-modal-close:hover { background: rgba(255,255,255,.18); transform: scale(1.1); }

        .short-modal-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: rgba(13,27,42,.88);
            color: var(--brand-gold, #d4af37);
            border: 1px solid rgba(212,175,55,.35);
            cursor: pointer;
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            transition: background .2s, color .2s, transform .2s;
            z-index: 1;
        }
        .short-modal-nav:hover {
            background: var(--brand-gold, #d4af37);
            color: #0e0e0e;
            transform: translateY(-50%) scale(1.1);
        }
        .short-modal-nav.prev { left: 1.25rem; }
        .short-modal-nav.next { right: 1.25rem; }

        @@media (min-width: 768px) {
            .short-modal-nav { display: inline-flex; }
        }
    </style>

    <script>
        /* ─── Drag carousel ─── */
        (function () {
            const viewport = document.getElementById('shortsCardsViewport');
            const track    = document.getElementById('shortsCardsTrack');
            if (!viewport || !track) return;

            let posX = 0;
            let dragging = false;
            let startX = 0, startPos = 0;
            let velocity = 0, lastX = 0, lastT = 0;
            let dragMoved = false;
            let rafId = null;

            function bounds() {
                return { min: Math.min(0, viewport.offsetWidth - track.scrollWidth), max: 0 };
            }
            function clamp(v, min, max) { return v > max ? max : v < min ? min : v; }
            function applyTransform(elastic) {
                const b = bounds();
                let x = posX;
                if (elastic) {
                    if (x > b.max) x = b.max + (x - b.max) * 0.3;
                    else if (x < b.min) x = b.min + (x - b.min) * 0.3;
                }
                track.style.transform = `translate3d(${x}px,0,0)`;
            }
            function dragStart(clientX) {
                dragging = true; dragMoved = false;
                startX = clientX; startPos = posX;
                velocity = 0; lastX = clientX; lastT = performance.now();
                viewport.classList.add('dragging');
                if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
            }
            function dragMove(clientX) {
                if (!dragging) return;
                const dx = clientX - startX;
                if (Math.abs(dx) > 5) dragMoved = true;
                posX = startPos + dx;
                const now = performance.now(), dt = now - lastT;
                if (dt > 0) velocity = (clientX - lastX) / dt * 16;
                lastX = clientX; lastT = now;
                applyTransform(true);
            }
            function dragEnd() {
                if (!dragging) return;
                dragging = false;
                viewport.classList.remove('dragging');
                inertiaSettle();
            }
            function inertiaSettle() {
                const b = bounds();
                function step() {
                    posX += velocity;
                    velocity *= 0.92;
                    if (posX > b.max) { posX += (b.max - posX) * 0.25; velocity *= 0.7; }
                    else if (posX < b.min) { posX += (b.min - posX) * 0.25; velocity *= 0.7; }
                    track.style.transform = `translate3d(${posX}px,0,0)`;
                    if (Math.abs(velocity) > 0.2 || posX > b.max + .5 || posX < b.min - .5) {
                        rafId = requestAnimationFrame(step);
                    } else {
                        posX = clamp(posX, b.min, b.max);
                        track.style.transform = `translate3d(${posX}px,0,0)`;
                    }
                }
                rafId = requestAnimationFrame(step);
            }

            viewport.addEventListener('mousedown', e => { e.preventDefault(); dragStart(e.clientX); });
            window.addEventListener('mousemove', e => dragMove(e.clientX));
            window.addEventListener('mouseup', dragEnd);
            viewport.addEventListener('mouseleave', () => { if (dragging) dragEnd(); });
            viewport.addEventListener('touchstart', e => dragStart(e.touches[0].clientX), { passive: true });
            viewport.addEventListener('touchmove', e => dragMove(e.touches[0].clientX), { passive: true });
            viewport.addEventListener('touchend', dragEnd);
            viewport.addEventListener('wheel', e => {
                if (Math.abs(e.deltaX) > Math.abs(e.deltaY)) return;
                e.preventDefault();
                posX = clamp(posX - e.deltaY, bounds().min, bounds().max);
                track.style.transform = `translate3d(${posX}px,0,0)`;
            }, { passive: false });

            track.querySelectorAll('.story-card').forEach(card => {
                card.addEventListener('click', e => {
                    if (dragMoved) { e.preventDefault(); e.stopPropagation(); }
                }, true);
            });
            window.addEventListener('resize', () => {
                posX = clamp(posX, bounds().min, bounds().max);
                track.style.transform = `translate3d(${posX}px,0,0)`;
            });
        })();

        /* ─── Modal player ─── */
        let _shortIndex = 0;
        let _shortCards = [];

        function _carregarShortNoModal(idx) {
            _shortCards = Array.from(document.querySelectorAll('#shortsCardsTrack .story-card'));
            if (_shortCards.length === 0) return;
            if (idx < 0) idx = _shortCards.length - 1;
            if (idx >= _shortCards.length) idx = 0;
            _shortIndex = idx;
            const card = _shortCards[idx];
            const id = card.dataset.videoId;
            const title = card.dataset.title || '';
            document.getElementById('shortIframe').src =
                `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0&modestbranding=1&playsinline=1`;
            document.getElementById('shortModalTitle').textContent = title;
            document.getElementById('shortModalLink').href = `https://www.youtube.com/shorts/${id}`;
        }

        function abrirShortModalCard(card, ev) {
            const idx = parseInt(card.dataset.index || '0', 10);
            const modal = document.getElementById('shortModal');
            modal.classList.add('open');
            modal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
            _carregarShortNoModal(idx);
        }

        function fecharShortModal() {
            const modal = document.getElementById('shortModal');
            modal.classList.remove('open');
            modal.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
            document.getElementById('shortIframe').src = '';
        }

        function navegarShort(delta) { _carregarShortNoModal(_shortIndex + delta); }

        document.addEventListener('keydown', e => {
            const modal = document.getElementById('shortModal');
            if (!modal || !modal.classList.contains('open')) return;
            if (e.key === 'Escape') fecharShortModal();
            else if (e.key === 'ArrowRight') navegarShort(1);
            else if (e.key === 'ArrowLeft')  navegarShort(-1);
        });
        document.getElementById('shortModal')?.addEventListener('click', e => {
            if (e.target.id === 'shortModal') fecharShortModal();
        });

        /* ─── Upgrade client-side: busca Shorts reais via rss2json (CORS-friendly).
               Servidor pode entregar fallback genérico (IP bloqueado pelo YouTube).
               Falha silenciosa — mantém o que veio do server. ─── */
        (async function upgradeShorts() {
            const section = document.getElementById('shorts-rail');
            if (!section) return;
            const channelId = section.dataset.channelId;
            if (!channelId || !channelId.startsWith('UC')) return;

            const playlistId = 'UUSH' + channelId.substring(2);
            const rssUrl = `https://www.youtube.com/feeds/videos.xml?playlist_id=${playlistId}`;
            const apiUrl = `https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(rssUrl)}&count=10`;

            try {
                const resp = await fetch(apiUrl);
                if (!resp.ok) return;
                const data = await resp.json();
                if (data.status !== 'ok' || !Array.isArray(data.items) || data.items.length === 0) return;

                const track = document.getElementById('shortsCardsTrack');
                if (!track) return;

                track.innerHTML = '';
                data.items.forEach((item, idx) => {
                    const m = (item.guid || item.link || '').match(/[a-zA-Z0-9_-]{11}/);
                    if (!m) return;
                    const id = m[0];
                    const title = (item.title || 'Vídeo').replace(/</g, '&lt;').replace(/"/g, '&quot;');

                    /* hqdefault sempre existe; maxresdefault como fallback de qualidade */
                    const portraitSrc = `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
                    const maxresSrc   = `https://i.ytimg.com/vi/${id}/maxresdefault.jpg`;
                    const hqSrc       = `https://i.ytimg.com/vi/${id}/mqdefault.jpg`;

                    const wrapper = document.createElement('div');
                    wrapper.className = 'story-card-wrapper';

                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = 'story-card';
                    btn.dataset.index = idx;
                    btn.dataset.videoId = id;
                    btn.dataset.title = item.title || 'Vídeo';
                    btn.setAttribute('aria-label', `Assistir: ${item.title || 'Vídeo'}`);
                    btn.onclick = function (ev) { abrirShortModalCard(this, ev); };
                    btn.innerHTML = `
                        <img src="${portraitSrc}"
                             alt="${title}"
                             loading="lazy"
                             draggable="false"
                             onerror="this.onerror=null;this.src='${maxresSrc}';this.onerror=function(){this.src='${hqSrc}'}" />
                        <div class="story-card-grad"></div>
                        <span class="story-card-badge" aria-label="Shorts">
                            <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                            Shorts
                        </span>
                        <div class="story-card-meta">
                            <h3 class="story-card-title">${title}</h3>
                        </div>
                        <div class="story-card-play" aria-hidden="true"><i class="fas fa-play"></i></div>
                        <div class="story-card-shine" aria-hidden="true"></div>
                    `;
                    wrapper.appendChild(btn);
                    track.appendChild(wrapper);
                });

                track.style.transform = 'translate3d(0,0,0)';

                /* Re-bloqueia click após drag para cards novos */
                track.querySelectorAll('.story-card').forEach(card => {
                    card.addEventListener('click', e => {
                        if (window._shortsDragMoved) { e.preventDefault(); e.stopPropagation(); }
                    }, true);
                });
            } catch (e) { /* mantém fallback do server */ }
        })();
    </script>
}
