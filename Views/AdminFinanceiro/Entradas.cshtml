@using BatistaFloramar.Domain.Entities
@model List<EntradaFinanceira>
@{
    ViewBag.AdminSection = "financeiro";
    ViewBag.Title = "Entradas Financeiras";
    Layout = "_AdminLayout";
    var meses = new[] { "","Jan","Fev","Mar","Abr","Mai","Jun","Jul","Ago","Set","Out","Nov","Dez" };
    var mesSel = ViewBag.MesSel as int?;
    var anoSel = (int)ViewBag.AnoSel;
    var tipoSel = ViewBag.TipoSel as string ?? "";
    var total = (decimal)ViewBag.Total;
    var ministerios = ViewBag.Ministerios as List<BatistaFloramar.Domain.Entities.Ministerio> ?? new();
}

@section TopbarActions {
    <a href="@Url.Action("Dashboard")" class="btn-admin btn-admin-sm" style="color:#1a1a2e">
        <i class="fas fa-arrow-left me-1"></i> Dashboard
    </a>
    <a href="@Url.Action("NovaEntrada")" class="btn-admin btn-admin-sm" style="background:var(--admin-success); color:#fff">
        <i class="fas fa-plus me-1"></i> Nova Entrada
    </a>
}

<style>
    .fin-filter-bar { background:var(--admin-card-bg); border:1px solid var(--admin-border); border-radius:10px; padding:1rem 1.25rem; margin-bottom:1.25rem; display:flex; flex-wrap:wrap; gap:.75rem; align-items:flex-end; }
    .fin-table-card { background:var(--admin-card-bg); border:1px solid var(--admin-border); border-radius:12px; overflow:hidden; }
    .fin-table { width:100%; border-collapse:collapse; }
    .fin-table th { font-size:.72rem; text-transform:uppercase; letter-spacing:.05em; color:var(--admin-text-muted); padding:.75rem 1rem; border-bottom:1px solid var(--admin-border); background:rgba(255,255,255,.02); }
    .fin-table td { padding:.7rem 1rem; border-bottom:1px solid rgba(255,255,255,.04); font-size:.88rem; vertical-align:middle; }
    .fin-table tr:last-child td { border-bottom:none; }
    .badge-tipo { display:inline-block; padding:2px 10px; border-radius:20px; font-size:.7rem; font-weight:700; }
    .badge-Dizimo    { background:rgba(212,175,55,.18); color:#d4af37; }
    .badge-Oferta    { background:rgba(37,162,90,.18); color:#25a25a; }
    .badge-Doacao    { background:rgba(52,152,219,.18); color:#3498db; }
    .badge-OfertaEspecifica { background:rgba(155,89,182,.18); color:#9b59b6; }
    .fin-total-bar { background:rgba(37,162,90,.1); border:1px solid rgba(37,162,90,.3); border-radius:10px; padding:.75rem 1.25rem; display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem; }
</style>

<form method="get" class="fin-filter-bar">
    <div>
        <label class="form-label mb-1" style="font-size:.75rem">Mês</label>
        <select name="mes" class="form-select form-select-sm" style="width:110px">
            <option value="">Todos</option>
            @for (int i = 1; i <= 12; i++)
            {
                if (mesSel == i) { <option value="@i" selected="selected">@meses[i]</option> }
                else { <option value="@i">@meses[i]</option> }
            }
        </select>
    </div>
    <div>
        <label class="form-label mb-1" style="font-size:.75rem">Ano</label>
        <select name="ano" class="form-select form-select-sm" style="width:90px">
            @foreach (var a in (List<int>)ViewBag.Anos)
            {
                if (anoSel == a) { <option value="@a" selected="selected">@a</option> }
                else { <option value="@a">@a</option> }
            }
        </select>
    </div>
    <div>
        <label class="form-label mb-1" style="font-size:.75rem">Tipo</label>
        <select name="tipo" class="form-select form-select-sm" style="width:160px">
            <option value="">Todos</option>
            @foreach (var opt in new[] {
                ("Dizimo","Dízimo"),("Oferta","Oferta"),
                ("OfertaEspecifica","Oferta Específica"),("Doacao","Doação")
            }) {
                if (tipoSel == opt.Item1) { <option value="@opt.Item1" selected="selected">@opt.Item2</option> }
                else { <option value="@opt.Item1">@opt.Item2</option> }
            }
        </select>
    </div>
    <div>
        <label class="form-label mb-1" style="font-size:.75rem">Ministério</label>
        <select name="ministerioId" class="form-select form-select-sm" style="width:160px">
            <option value="">Todos</option>
            @foreach (var m in ministerios)
            {
                <option value="@m.Id">@m.Nome</option>
            }
        </select>
    </div>
    <button type="submit" class="btn-admin btn-admin-sm"><i class="fas fa-filter me-1"></i> Filtrar</button>
    <a href="@Url.Action("Entradas")" class="btn-admin btn-admin-sm" style="background:transparent; border:1px solid var(--admin-border); color:var(--admin-text)">Limpar</a>
</form>

<div class="fin-total-bar">
    <span style="font-size:.85rem; color:var(--admin-text-muted)">@Model.Count registro(s) encontrado(s)</span>
    <span style="font-weight:700; color:#25a25a; font-size:1.05rem">Total: R$ @total.ToString("N2")</span>
</div>

<div class="fin-table-card">
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
            Nenhuma entrada encontrada com os filtros selecionados.
        </div>
    }
    else
    {
        <table class="fin-table">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Tipo</th>
                    <th>Descrição</th>
                    <th>Origem</th>
                    <th>Ministério</th>
                    <th>Registrado por</th>
                    <th style="text-align:right">Valor</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>@e.Data.ToString("dd/MM/yyyy")</td>
                        <td><span class="badge-tipo badge-@e.Tipo">@BatistaFloramar.Application.Services.FinanceiroService.TipoEntradaLabel(e.Tipo.ToString())</span></td>
                        <td>@e.Descricao</td>
                        <td style="color:var(--admin-text-muted)">@(e.Origem ?? "—")</td>
                        <td style="color:var(--admin-text-muted)">@(e.Ministerio?.Nome ?? "—")</td>
                        <td style="color:var(--admin-text-muted); font-size:.78rem">@(e.RegistradoPor ?? "—")</td>
                        <td style="text-align:right; color:#25a25a; font-weight:700">R$ @e.Valor.ToString("N2")</td>
                        <td>
                            <form method="post" action="@Url.Action("ExcluirEntrada")" onsubmit="return confirm('Excluir este registro?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@e.Id" />
                                <button type="submit" class="btn-admin btn-admin-sm" style="background:#c0392b; padding:3px 10px"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
