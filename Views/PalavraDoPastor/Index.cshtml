@model List<BatistaFloramar.Domain.Entities.PalavraDoPastor>
@{
    ViewBag.Title = "Palavra do Pastor";
    Layout = "_Layout";
}

<div class="page-card">
    <div class="page-header">
        <span class="section-eyebrow">Reflexão & Edificação</span>
        <h1 class="page-title">Palavra do Pastor</h1>
        <p class="page-subtitle">
            Sermões, devocionais e reflexões escritas pelo pastor para edificar e fortalecer sua fé.
        </p>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="section-card mt-4 text-center py-5">
            <i class="fas fa-pen-nib text-gold" style="font-size:2.5rem;margin-bottom:1rem;display:block;"></i>
            <p class="text-secondary">Nenhuma palavra publicada ainda. Volte em breve!</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-4 mt-2">
            @foreach (var p in Model)
            {
                <div class="col">
                    <a href="/PalavraDoPastor/Detalhe/@p.Id" class="text-decoration-none">
                        <div class="section-card h-100" style="transition:transform .2s,box-shadow .2s;cursor:pointer;"
                             onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,.4)'"
                             onmouseout="this.style.transform='';this.style.boxShadow=''">
                            @if (!string.IsNullOrEmpty(p.ImagemDestaque))
                            {
                                <img src="@p.ImagemDestaque" alt="@p.Titulo"
                                     style="width:100%;height:180px;object-fit:cover;border-radius:10px;margin-bottom:1rem;" />
                            }
                            <div class="d-flex align-items-center gap-2 mb-2">
                                @if (p.Tipo == BatistaFloramar.Domain.Entities.TipoPalavra.Sermao)
                                {
                                    <span style="background:#1a3a6a;color:#8af;font-size:.72rem;font-weight:700;padding:.2rem .6rem;border-radius:4px;letter-spacing:.04em;">SERMÃO</span>
                                }
                                else
                                {
                                    <span style="background:#3a2505;color:#f4a;font-size:.72rem;font-weight:700;padding:.2rem .6rem;border-radius:4px;letter-spacing:.04em;">DEVOCIONAL</span>
                                }
                                <span class="text-secondary small">@p.DataPublicacao.ToString("dd/MM/yyyy")</span>
                            </div>
                            <h3 style="color:#fff;font-size:1.1rem;margin:0 0 .5rem;line-height:1.35;">@p.Titulo</h3>
                            <p class="text-secondary small mb-0"><i class="fas fa-user me-1 text-gold"></i>@p.AutorNome</p>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>
