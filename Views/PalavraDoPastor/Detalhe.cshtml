@model BatistaFloramar.Domain.Entities.PalavraDoPastor
@{
    ViewBag.Title = Model.Titulo + " | Palavra do Pastor";
    Layout = "_Layout";
    ViewBag.FullWidth = true;

    var shareUrl = "https://www.batistafloramar.com.br/PalavraDoPastor/Detalhe/" + Model.Slug;
    var shareWa  = "https://wa.me/?text=" + Uri.EscapeDataString(Model.Titulo + " — " + shareUrl);
    var isSermao = Model.Tipo == BatistaFloramar.Domain.Entities.TipoPalavra.Sermao;
    var dataFormatada = Model.DataPublicacao.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("pt-BR"));
}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet">

<!-- Barra de progresso de leitura -->
<div class="reading-progress" id="reading-progress"></div>

<style>
    .reading-progress {
        position: fixed;
        top: 0; left: 0;
        height: 4px;
        width: 0%;
        background: linear-gradient(90deg, #e6c15a, #d4af3e);
        box-shadow: 0 0 10px rgba(230,193,90,.6);
        z-index: 2000;
        transition: width .1s linear;
    }

    .palavra-detalhe-hero {
        background: radial-gradient(ellipse at top, var(--bg-tertiary) 0%, var(--bg-primary) 60%);
        padding: 5rem 0 3.5rem;
        text-align: center;
        border-bottom: 1px solid var(--brand-gold-border);
        position: relative;
        overflow: hidden;
    }
    .palavra-detalhe-hero::before {
        content: '';
        position: absolute; inset: 0;
        background: radial-gradient(ellipse 60% 50% at 50% 100%, var(--brand-gold-light) 0%, transparent 70%);
    }
    .palavra-detalhe-hero > .container { position: relative; max-width: 760px; }

    .tipo-badge-sermao   { background: #1a3a6a; color: #8af;  font-size: .78rem; font-weight: 700; padding: .3rem .8rem; border-radius: 5px; letter-spacing: .04em; }
    .tipo-badge-devocional { background: #3a2505; color: #f4a; font-size: .78rem; font-weight: 700; padding: .3rem .8rem; border-radius: 5px; letter-spacing: .04em; }

    .palavra-detalhe-hero h1 {
        font-size: clamp(1.7rem, 4vw, 2.8rem);
        font-weight: 800;
        color: var(--text-primary);
        line-height: 1.22;
        margin: .75rem 0 1rem;
    }
    .palavra-meta { color: var(--text-secondary); font-size: .92rem; display: flex; align-items: center; justify-content: center; gap: 1.25rem; flex-wrap: wrap; }
    .palavra-meta i { color: var(--brand-gold); }

    .palavra-detalhe-cover {
        max-width: 960px;
        margin: 0 auto;
        padding: 0 1rem;
        transform: translateY(-2rem);
    }
    .palavra-detalhe-cover img {
        width: 100%;
        max-height: 420px;
        object-fit: cover;
        border-radius: calc(var(--radius) * 1.5);
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: var(--shadow-soft);
        display: block;
    }

    .palavra-detalhe-body {
        max-width: 960px;
        margin: 0 auto;
        padding: 2rem 1rem 4rem;
    }
    .palavra-detalhe-body .prose {
        background: var(--bg-tertiary);
        border: 1px solid rgba(255,255,255,.07);
        border-radius: calc(var(--radius) * 1.5);
        padding: 3.25rem 3.5rem;
        font-family: 'Lora', Georgia, 'Times New Roman', serif;
        font-size: var(--reading-fs, 1.2rem);
        line-height: 1.9;
        color: #d4e2f0;
        letter-spacing: .002em;
        text-wrap: pretty;
        hyphens: auto;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    /* medida de leitura confortável: card largo, mas texto numa coluna de ~68ch centralizada */
    .palavra-detalhe-body .prose-inner {
        width: 100%;
        max-width: 68ch;
    }
    .palavra-detalhe-body .prose ::selection {
        background: rgba(230,193,90,.3);
        color: #fff;
    }
    /* Tamanhos inline vindos do editor (Quill) */
    .palavra-detalhe-body .prose .ql-size-small { font-size: 0.75em; }
    .palavra-detalhe-body .prose .ql-size-large { font-size: 1.5em; }
    .palavra-detalhe-body .prose .ql-size-huge  { font-size: 2.2em; }

    /* Tipografia de leitura dentro do conteúdo */
    .palavra-detalhe-body .prose-inner > *:first-child { margin-top: 0; }
    .palavra-detalhe-body .prose-inner > *:last-child { margin-bottom: 0; }
    .palavra-detalhe-body .prose p { margin-top: 0; margin-bottom: 1.5rem; }
    .palavra-detalhe-body .prose h1,
    .palavra-detalhe-body .prose h2,
    .palavra-detalhe-body .prose h3,
    .palavra-detalhe-body .prose h4 {
        color: var(--text-primary);
        font-weight: 700;
        line-height: 1.3;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
    }
    .palavra-detalhe-body .prose h2 { font-size: 1.6rem; }
    .palavra-detalhe-body .prose h3 { font-size: 1.35rem; color: var(--brand-gold); }
    .palavra-detalhe-body .prose h4 { font-size: 1.15rem; }
    .palavra-detalhe-body .prose strong { color: #fff; font-weight: 700; }
    .palavra-detalhe-body .prose a { color: var(--brand-gold); text-decoration: underline; text-underline-offset: 3px; }
    .palavra-detalhe-body .prose ul,
    .palavra-detalhe-body .prose ol { margin-top: 0; margin-bottom: 1.5rem; padding-left: 1.5rem; }
    .palavra-detalhe-body .prose li { margin-bottom: .6rem; }
    .palavra-detalhe-body .prose blockquote {
        margin-top: 2rem;
        margin-bottom: 2rem;
        padding: 1.25rem 1.75rem;
        border-left: 4px solid var(--brand-gold);
        background: rgba(230,193,90,.06);
        border-radius: 0 10px 10px 0;
        color: #e8eef5;
        font-style: italic;
    }
    .palavra-detalhe-body .prose blockquote p:last-child { margin-bottom: 0; }
    .palavra-detalhe-body .prose img {
        max-width: 100%;
        height: auto;
        border-radius: 10px;
        margin: 1.5rem 0;
    }
    .palavra-detalhe-body .prose hr {
        border: 0;
        border-top: 1px solid rgba(255,255,255,.1);
        margin: 2.5rem 0;
    }

    .reading-toolbar {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: .6rem;
        margin-bottom: 1rem;
    }
    .reading-toolbar span {
        color: var(--text-secondary);
        font-size: .78rem;
        margin-right: .1rem;
    }
    .fs-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 38px; height: 38px;
        border-radius: 999px;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.14);
        color: #d4e2f0;
        cursor: pointer;
        transition: all .2s ease;
        line-height: 1;
    }
    .fs-btn .fa-font { pointer-events: none; }
    .fs-btn.small { font-size: .72rem; }
    .fs-btn.large { font-size: 1.02rem; }
    .fs-btn:hover { background: rgba(230,193,90,.14); border-color: rgba(230,193,90,.45); color: #e6c15a; }
    .fs-btn:disabled { opacity: .35; cursor: default; }
    .fs-btn:disabled:hover { background: rgba(255,255,255,.06); border-color: rgba(255,255,255,.14); color: #d4e2f0; }

    .palavra-nav-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        padding-top: 1.5rem;
        margin-top: 1.5rem;
        border-top: 1px solid rgba(255,255,255,.08);
    }

    .btn-back-palavra {
        display: inline-flex; align-items: center; gap: .5rem;
        color: var(--text-secondary); font-size: .9rem; font-weight: 600;
        text-decoration: none;
        transition: color var(--transition-fast);
    }
    .btn-back-palavra:hover { color: var(--brand-gold); }
    .btn-back-palavra i { font-size: .85rem; }

    .btn-share-pill {
        display: inline-flex; align-items: center; gap: .45rem;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.12);
        color: #c8d8e8;
        border-radius: 999px;
        padding: .4rem .95rem;
        font-size: .82rem; font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast);
        white-space: nowrap;
    }
    .btn-share-pill:hover { background: rgba(230,193,90,.14); border-color: rgba(230,193,90,.4); color: #e6c15a; }
    .btn-share-wa { color: #4cda7a; border-color: rgba(76,218,122,.25); background: rgba(76,218,122,.08); }
    .btn-share-wa:hover { background: rgba(76,218,122,.18); border-color: rgba(76,218,122,.5); color: #4cda7a; }

    .share-toast {
        position: fixed; bottom: 1.5rem; left: 50%;
        transform: translateX(-50%) translateY(1rem);
        background: #1e2e4e; color: #c8d8e8;
        border: 1px solid rgba(230,193,90,.3);
        border-radius: 10px; padding: .6rem 1.25rem;
        font-size: .85rem; font-weight: 600;
        opacity: 0; pointer-events: none;
        transition: opacity .25s, transform .25s;
        z-index: 9999; white-space: nowrap;
    }
    .share-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    .cta-block {
        background: var(--bg-secondary);
        border-top: 1px solid var(--brand-gold-border);
        padding: 5rem 0;
        text-align: center;
    }
    .cta-block h2 { color: var(--text-primary); font-weight: 700; font-size: clamp(1.5rem,3vw,2rem); margin-bottom: .75rem; }
    .cta-block p { color: var(--text-secondary); max-width: 540px; margin: 0 auto 2rem; }

    @@media (max-width: 767px) {
        .palavra-detalhe-body .prose { padding: 1.75rem 1.5rem; font-size: 1.08rem; }
        .palavra-detalhe-body .prose h2 { font-size: 1.4rem; }
        .palavra-detalhe-body .prose h3 { font-size: 1.2rem; }
    }
    @@media (max-width: 480px) {
        .btn-share-label { display: none; }
        .btn-share-pill { padding: .4rem .7rem; }
    }
</style>

<!-- Hero -->
<div class="palavra-detalhe-hero">
    <div class="container">
        <div class="mb-2">
            @if (isSermao)
            {
                <span class="tipo-badge-sermao">SERMÃO</span>
            }
            else
            {
                <span class="tipo-badge-devocional">DEVOCIONAL</span>
            }
        </div>
        <h1>@Model.Titulo</h1>
        <div class="palavra-meta">
            <span><i class="fas fa-user me-1"></i>@Model.AutorNome</span>
            <span><i class="fas fa-calendar me-1"></i>@dataFormatada</span>
        </div>
    </div>
</div>

<!-- Imagem destaque -->
@if (!string.IsNullOrEmpty(Model.ImagemDestaque))
{
    <div class="palavra-detalhe-cover">
        <img src="@Model.ImagemDestaque" alt="@Model.Titulo" loading="lazy" />
    </div>
}

<!-- Conteúdo -->
<div class="palavra-detalhe-body">
    <!-- Controle de tamanho da fonte -->
    <div class="reading-toolbar">
        <span>Tamanho do texto</span>
        <button type="button" class="fs-btn small" id="fs-decrease" title="Diminuir texto" aria-label="Diminuir texto">
            <i class="fas fa-font"></i>
        </button>
        <button type="button" class="fs-btn large" id="fs-increase" title="Aumentar texto" aria-label="Aumentar texto">
            <i class="fas fa-font"></i>
        </button>
    </div>

    <div class="prose">
        <div class="prose-inner">
            @Html.Raw(Model.Conteudo)
        </div>
    </div>

    <!-- Navegação + Share -->
    <div class="palavra-nav-row">
        <a href="/PalavraDoPastor" class="btn-back-palavra">
            <i class="fas fa-arrow-left"></i> Ver todas as palavras
        </a>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="text-secondary" style="font-size:.75rem;">Compartilhar:</span>
            <button id="btn-share-native" class="btn-share-pill" title="Compartilhar" onclick="compartilharNativo()">
                <i class="fas fa-share-alt"></i><span class="btn-share-label">Compartilhar</span>
            </button>
            <a class="btn-share-pill btn-share-wa" href="@shareWa" target="_blank" rel="noopener noreferrer" title="Compartilhar no WhatsApp">
                <i class="fab fa-whatsapp"></i><span class="btn-share-label">WhatsApp</span>
            </a>
            <button class="btn-share-pill" title="Copiar link" onclick="copiarLink()">
                <i class="fas fa-link"></i><span class="btn-share-label">Copiar link</span>
            </button>
        </div>
    </div>
</div>

<div id="share-toast" class="share-toast" aria-live="polite"></div>

<!-- CTA -->
<div class="cta-block">
    <div class="container">
        <h2>Ficou com alguma dúvida ou pedido de oração?</h2>
        <p>Envie uma mensagem ao pastor. Nossa equipe cuidará do encaminhamento com atenção e carinho.</p>
        <div class="d-flex flex-wrap justify-content-center gap-3">
            <a href="/Napalavra" class="btn btn-primary btn-lg">
                <i class="fas fa-comment-dots me-2"></i> Enviar Mensagem ao Pastor
            </a>
            <a href="/PalavraDoPastor" class="btn btn-outline-hero btn-lg">
                <i class="fas fa-book-open me-2"></i> Ver Mais Palavras
            </a>
        </div>
    </div>
</div>

<script>
    var _shareUrl   = '@shareUrl';
    var _shareTitle = '@Html.Raw(Model.Titulo.Replace("'", "\\'"))';
    var _shareText  = 'Leia "@Html.Raw(Model.Titulo.Replace("'", "\\'"))" — Palavra do Pastor | Comunidade Batista Floramar';

    if (!navigator.share) {
        document.getElementById('btn-share-native').style.display = 'none';
    }

    function mostrarToast(msg) {
        var t = document.getElementById('share-toast');
        t.textContent = msg;
        t.classList.add('show');
        setTimeout(function () { t.classList.remove('show'); }, 2500);
    }

    function compartilharNativo() {
        if (navigator.share) {
            navigator.share({ title: _shareTitle, text: _shareText, url: _shareUrl }).catch(function () {});
        }
    }

    function copiarLink() {
        if (navigator.clipboard) {
            navigator.clipboard.writeText(_shareUrl).then(function () { mostrarToast('✓ Link copiado!'); });
        } else {
            var el = document.createElement('textarea');
            el.value = _shareUrl;
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);
            mostrarToast('✓ Link copiado!');
        }
    }

    /* ── Barra de progresso de leitura ── */
    (function () {
        var bar = document.getElementById('reading-progress');
        var article = document.querySelector('.palavra-detalhe-body');
        if (!bar || !article) return;

        function updateProgress() {
            var start = article.offsetTop;
            var total = article.offsetHeight - window.innerHeight;
            var scrolled = window.scrollY - start;
            var pct = total > 0 ? (scrolled / total) * 100 : 0;
            pct = Math.max(0, Math.min(100, pct));
            bar.style.width = pct + '%';
        }
        window.addEventListener('scroll', updateProgress, { passive: true });
        window.addEventListener('resize', updateProgress);
        updateProgress();
    })();

    /* ── Controle de tamanho do texto (A- / A+) ── */
    (function () {
        var prose = document.querySelector('.palavra-detalhe-body .prose');
        var btnDec = document.getElementById('fs-decrease');
        var btnInc = document.getElementById('fs-increase');
        if (!prose || !btnDec || !btnInc) return;

        var MIN = 1.0, MAX = 1.7, STEP = 0.1, DEFAULT = 1.2;
        var size = parseFloat(localStorage.getItem('palavraFontSize')) || DEFAULT;

        function apply() {
            size = Math.round(size * 10) / 10;
            prose.style.setProperty('--reading-fs', size + 'rem');
            localStorage.setItem('palavraFontSize', size);
            btnDec.disabled = size <= MIN + 0.001;
            btnInc.disabled = size >= MAX - 0.001;
        }
        btnDec.addEventListener('click', function () { if (size > MIN) { size -= STEP; apply(); } });
        btnInc.addEventListener('click', function () { if (size < MAX) { size += STEP; apply(); } });
        apply();
    })();
</script>
