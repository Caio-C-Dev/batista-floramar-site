@using BatistaFloramar.Domain.Entities
@model Ministerio
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Editar Ministério";
    ViewBag.AdminSection = "ministerios";
}

@section TopbarActions {
    <a href="@Url.Action("Index")" class="btn-admin-outline">
        <i class="fas fa-arrow-left"></i> Voltar
    </a>
}

<div class="admin-card" style="max-width: 720px;">
    <form method="post" asp-action="Edit" class="admin-form">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="row g-3">
            <div class="col-md-8">
                <label asp-for="Nome">Nome do Ministério</label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="field-validation-error"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Ordem">Ordem</label>
                <input asp-for="Ordem" type="number" class="form-control" min="0" />
            </div>
            <div class="col-12">
                <label asp-for="Descricao">Descrição</label>
                <textarea asp-for="Descricao" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Descricao" class="field-validation-error"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Lideranca">Liderança</label>
                <input asp-for="Lideranca" class="form-control" />
                <span asp-validation-for="Lideranca" class="field-validation-error"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="WhatsApp">WhatsApp do Líder</label>
                <input asp-for="WhatsApp" class="form-control" placeholder="5531999990000" />
                <span class="text-muted" style="font-size:.8rem">Somente dígitos com DDI: ex. 5531985339161</span>
            </div>
            <div class="col-12">
                <label asp-for="FotoLider">Foto do Líder (caminho relativo)</label>
                <input asp-for="FotoLider" class="form-control" placeholder="/images/ministerios/lideres/NomeDoLider.jpeg" />
                <span class="text-muted" style="font-size:.8rem">Coloque o arquivo em <code>wwwroot/images/ministerios/lideres/</code> e informe o caminho aqui. Deixe em branco para usar o ícone padrão.</span>
                @if (!string.IsNullOrEmpty(Model.FotoLider))
                {
                <div class="mt-2">
                    <img src="@Model.FotoLider" alt="Prévia" style="width:52px;height:52px;object-fit:cover;border-radius:50%;border:2px solid rgba(230,193,90,0.4);" />
                </div>
                }
            </div>
            <div class="col-md-8">
                <label asp-for="Slug">Slug (URL)</label>
                <input asp-for="Slug" class="form-control" placeholder="jovens" />
                <span class="text-muted" style="font-size:.8rem">Letras minúsculas e hífens. Ex.: acao-social</span>
            </div>
            <div class="col-md-4">
                <label asp-for="Icone">Ícone FontAwesome</label>
                <input asp-for="Icone" class="form-control" />
                <span class="text-muted">Ex.: <code style="color:var(--admin-accent)">fas fa-music</code></span>
            </div>
            <div class="col-12">
                <label asp-for="ResumoBreve">Resumo breve (listagem)</label>
                <input asp-for="ResumoBreve" class="form-control" maxlength="300" />
            </div>
            <div class="col-12">
                <label asp-for="Link">Link (opcional)</label>
                <input asp-for="Link" class="form-control" placeholder="/Missao" />
                <span class="text-muted">Deixe em branco se não houver link especial.</span>
            </div>
            <div class="col-12">
                <div class="form-check">
                    <input asp-for="Ativo" class="form-check-input" type="checkbox" />
                    <label asp-for="Ativo" class="form-check-label" style="text-transform:none; font-size: 0.9rem; color: var(--admin-text);">
                        Ministério ativo (visível no site)
                    </label>
                </div>
            </div>
            <div class="col-12 pt-2">
                <button type="submit" class="btn-admin">
                    <i class="fas fa-save"></i> Salvar Alterações
                </button>
            </div>
        </div>
    </form>
</div>
