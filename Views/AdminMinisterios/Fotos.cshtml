@using BatistaFloramar.Domain.Entities
@model Ministerio
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i> Ministérios
    </a>
    <div>
        <h4 class="mb-0">Fotos — <span class="text-gold">@Model.Nome</span></h4>
        <p class="text-secondary small mb-0">Liderança: @Model.Lideranca</p>
    </div>
    <a href="/Ministerios/Detalhes/@Model.Slug" target="_blank" class="btn btn-sm btn-secondary ms-auto">
        <i class="fas fa-eye me-1"></i> Ver no site
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="section-card mb-4">
    <h5 class="mb-3"><i class="fas fa-upload text-gold me-2"></i>Adicionar foto</h5>
    <form method="post" action="@Url.Action("UploadFoto")" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Arquivo (JPG, PNG, WEBP — máx. 5 MB)</label>
                <input type="file" name="arquivo" class="form-control" accept="image/*" required />
            </div>
            <div class="col-md-5">
                <label class="form-label">Legenda (opcional)</label>
                <input type="text" name="legenda" class="form-control" maxlength="300" placeholder="Ex: Culto especial de jovens" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-upload me-1"></i> Enviar
                </button>
            </div>
        </div>
    </form>
</div>

@if (Model.Fotos.Any())
{
    <div class="row g-3">
        @foreach (var foto in Model.Fotos.OrderByDescending(f => f.DataUpload))
        {
            <div class="col-6 col-md-4 col-lg-3">
                <div class="section-card p-2 text-center h-100 d-flex flex-column">
                    <img src="@foto.CaminhoArquivo" alt="@foto.Legenda"
                         class="img-fluid rounded-3 mb-2"
                         style="width:100%;height:160px;object-fit:cover;" />
                    @if (!string.IsNullOrEmpty(foto.Legenda))
                    {
                        <p class="text-secondary small mb-2 flex-grow-1">@foto.Legenda</p>
                    }
                    <p class="text-secondary" style="font-size:.75rem">@foto.DataUpload.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                    <form method="post" action="@Url.Action("DeleteFoto")"
                          onsubmit="return confirm('Remover esta foto?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="fotoId" value="@foto.Id" />
                        <input type="hidden" name="ministerioId" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger btn-sm w-100">
                            <i class="fas fa-trash me-1"></i> Remover
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="section-card text-center py-5 text-secondary">
        <i class="fas fa-images fa-2x mb-3 opacity-50"></i>
        <p class="mb-0">Nenhuma foto ainda. Adicione a primeira acima!</p>
    </div>
}
