@{
    ViewBag.Title = "Notícias";
    Layout = "_Layout";
}

<div class="page-card">
    <div class="page-header">
        <span class="section-eyebrow">Acontecimentos da Igreja</span>
        <h1 class="page-title">Notícias & Eventos</h1>
        <p class="page-subtitle">
            Confira os últimos encontros, celebrações e ações comunitárias da Comunidade Batista Floramar.
        </p>
    </div>

    <div class="row row-cols-1 row-cols-md-2 g-4 mt-2">
        <div class="col">
            <div class="section-card h-100">
                <h3><i class="fas fa-church me-2 text-gold"></i>Culto de Celebração</h3>
                <p class="text-secondary">Uma noite de louvor, oração e mensagem transformadora.</p>
                <p class="text-secondary small"><i class="fas fa-calendar me-1"></i> 25 de março de 2026</p>
            </div>
        </div>
        <div class="col">
            <div class="section-card h-100">
                <h3><i class="fas fa-box-open me-2 text-gold"></i>Campanha Solidária</h3>
                <p class="text-secondary">Distribuição de cestas e apoio a famílias da região do Floramar.</p>
                <p class="text-secondary small"><i class="fas fa-calendar me-1"></i> 10 de março de 2026</p>
            </div>
        </div>
        <div class="col">
            <div class="section-card h-100">
                <h3><i class="fas fa-mountain me-2 text-gold"></i>Retiro Espiritual</h3>
                <p class="text-secondary">Momentos de oração e renovação em meio à natureza.</p>
                <p class="text-secondary small"><i class="fas fa-calendar me-1"></i> 5 de fevereiro de 2026</p>
            </div>
        </div>
        <div class="col">
            <div class="section-card h-100">
                <h3><i class="fas fa-praying-hands me-2 text-gold"></i>Semana da Oração</h3>
                <p class="text-secondary">Dias dedicados à comunhão e fortalecimento espiritual da congregação.</p>
                <p class="text-secondary small"><i class="fas fa-calendar me-1"></i> 20 de janeiro de 2026</p>
            </div>
        </div>
    </div>
</div>

