@{
    Layout = "_Layout";
    ViewBag.Title = "Página Não Encontrada";
    ViewBag.MetaDescription = "A página que você procura não foi encontrada. Volte para a Comunidade Batista Floramar e encontre o que precisa.";
    ViewBag.FullWidth = false;
}

<div class="notfound-wrap text-center py-5">

    <div class="notfound-icon mb-4">
        <i class="fas fa-map-signs"></i>
    </div>

    <p class="section-eyebrow mb-3">Erro 404</p>
    <h1 class="notfound-title mb-3">Página não encontrada</h1>
    <p class="notfound-subtitle mb-5">
        Talvez você esteja procurando por nossa igreja.<br>
        Que tal começar pelo início e encontrar o que precisa?
    </p>

    <div class="d-flex flex-wrap justify-content-center gap-3">
        <a href="/" class="btn btn-primary btn-lg">
            <i class="fas fa-home me-2"></i>Voltar para o Início
        </a>
        <a href="/Visita" class="btn btn-outline-gold btn-lg">
            <i class="fas fa-calendar-check me-2"></i>Planejar Visita
        </a>
        <a href="/Napalavra" class="btn btn-outline-gold btn-lg">
            <i class="fas fa-envelope me-2"></i>Fale Conosco
        </a>
    </div>

    <p class="notfound-hint mt-5">
        <i class="fas fa-church me-2" style="color:var(--brand-gold)"></i>
        <strong>Comunidade Batista Floramar</strong> — Rua José Lima de Almeida, 59 · Floramar, BH
    </p>

</div>

<style>
    .notfound-wrap {
        max-width: 640px;
        margin: 0 auto;
    }
    .notfound-icon {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: rgba(230, 193, 90, 0.08);
        border: 1px solid rgba(230, 193, 90, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: var(--brand-gold, #e6c15a);
        margin: 0 auto;
    }
    .notfound-title {
        font-size: clamp(2rem, 6vw, 3rem);
        font-weight: 800;
        color: var(--text-primary, #fff);
        letter-spacing: -0.02em;
    }
    .notfound-subtitle {
        font-size: 1.1rem;
        color: var(--text-secondary, #b0b0b0);
        line-height: 1.7;
    }
    .notfound-hint {
        font-size: 0.9rem;
        color: var(--text-secondary, #b0b0b0);
    }
</style>
