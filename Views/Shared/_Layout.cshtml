<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    @{
        var pageTitle       = ViewBag.Title != null
                                ? ViewBag.Title + " | Comunidade Batista Floramar – Belo Horizonte"
                                : "Comunidade Batista Floramar – Igreja em Floramar, Belo Horizonte";
        var pageDescription = ViewBag.MetaDescription as string
                                ?? "Igreja evangélica batista no Floramar, Belo Horizonte – MG. Cultos aos Domingos 10h e 18h e Quartas 20h. Venha crescer na Palavra, servir e fazer parte da nossa família.";
        var rawPath         = Context.Request.Path.Value ?? "/";
        // Normaliza rotas padrão do MVC para URL limpa (sem /Home/Index)
        var normalizedPath  = rawPath.Equals("/Home/Index", StringComparison.OrdinalIgnoreCase)
                                  || rawPath.Equals("/Home", StringComparison.OrdinalIgnoreCase)
                                ? "/"
                                : rawPath;
        var canonicalUrl    = ViewBag.CanonicalUrl as string
                                ?? "https://www.batistafloramar.com.br" + normalizedPath;
        var ogImage         = ViewBag.OgImage as string
                                ?? "https://www.batistafloramar.com.br/images/church-logo.png";
    }

    <title>@pageTitle</title>
    <meta name="description" content="@pageDescription" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Comunidade Batista Floramar" />
    <meta name="keywords" content="igreja em Floramar, igreja em Belo Horizonte, igreja batista BH, culto evangélico BH, célula de crescimento BH, igreja próxima Floramar, culto Belo Horizonte, Comunidade Batista Floramar" />
    <link rel="canonical" href="@canonicalUrl" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:locale"      content="pt_BR" />
    <meta property="og:site_name"   content="Comunidade Batista Floramar" />
    <meta property="og:title"       content="@pageTitle" />
    <meta property="og:description" content="@pageDescription" />
    <meta property="og:url"         content="@canonicalUrl" />
    <meta property="og:image"       content="@ogImage" />
    <meta property="og:image:alt"   content="Logo da Comunidade Batista Floramar" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content="@pageTitle" />
    <meta name="twitter:description" content="@pageDescription" />
    <meta name="twitter:image"       content="@ogImage" />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": ["Church", "LocalBusiness"],
      "name": "Comunidade Batista Floramar",
      "alternateName": "Igreja Batista Floramar",
      "description": "Igreja evangélica batista no bairro Floramar, Belo Horizonte – MG. Cultos, células, ministérios e palavra expositiva.",
      "url": "https://www.batistafloramar.com.br",
      "logo": "https://www.batistafloramar.com.br/images/church-logo.png",
      "image": "https://www.batistafloramar.com.br/images/church-logo.png",
      "telephone": "",
      "address": {
        "@@type": "PostalAddress",
        "streetAddress": "Rua José Lima de Almeida, 59",
        "addressLocality": "Belo Horizonte",
        "addressRegion": "MG",
        "postalCode": "31710-140",
        "addressCountry": "BR",
        "neighborhood": "Floramar"
      },
      "geo": {
        "@@type": "GeoCoordinates",
        "latitude":  "-19.8423",
        "longitude": "-43.9502"
      },
      "openingHoursSpecification": [
        { "@@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday",    "opens": "10:00", "closes": "12:00" },
        { "@@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday",    "opens": "18:00", "closes": "20:00" },
        { "@@type": "OpeningHoursSpecification", "dayOfWeek": "Wednesday", "opens": "20:00", "closes": "22:00" }
      ],
      "sameAs": [
        "https://www.facebook.com/batistafloramar/",
        "https://www.instagram.com/batistafloramar/",
        "https://www.youtube.com/@@comunidadebatistafloramar"
      ]
    }
    </script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/images/church-logo.png" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-xl navbar-dark main-navbar shadow-sm">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                    <img src="~/images/church-logo.png" alt="Logo da Comunidade Batista Floramar – Igreja em Floramar BH" class="navbar-logo" />
                    <span class="fw-bold d-none d-xxl-inline">Comunidade Batista Floramar</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Alternar navegação">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        <li class="nav-item"><a class="nav-link" href="/">Início</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Sobre">Sobre</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Cultos">Cultos</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Celula">Células</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Ministerios">Ministérios</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Aovivo">Ao Vivo</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Podcast">Podcast</a></li>
                        <li class="nav-item"><a class="nav-link" href="/PalavraDoPastor">Palavra do Pastor</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Series">Séries</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Doacao">Doações</a></li>
                        <li class="nav-item ms-lg-2"><a class="nav-link btn-nav-contact" href="/Napalavra">Contato</a></li>
                        <li class="nav-item ms-lg-2"><a class="nav-link btn-nav-pastor" href="/Admin/Login"><i class="fas fa-cross me-1"></i>Área do Pastor</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-fill">
        @if (ViewBag.FullWidth == true)
        {
            @RenderBody()
        }
        else
        {
            <div class="container py-5">
                @RenderBody()
            </div>
        }
    </main>

    <footer class="site-footer mt-auto">
        <div class="container">
            <div class="footer-shell">
                <div class="row g-4 align-items-start">
                    <div class="col-lg-4">
                        <div class="footer-brand-block">
                            <img src="~/images/church-logo.png" alt="Logo da Comunidade Batista Floramar" class="footer-logo-image" />
                            <div>
                                <h5 class="mb-2">Comunidade Batista Floramar</h5>
                                <p class="mb-0 text-secondary">Uma igreja Bíblica que se preocupa com a exposição da palavra na íntegra.</p>
                            </div>
                        </div>
                        <div class="footer-address mt-3">
                            <p class="mb-1"><i class="fas fa-map-marker-alt me-2" style="color:var(--brand-gold)"></i><strong>Rua José Lima de Almeida, 59</strong><br><span class="text-secondary">Floramar, Belo Horizonte – MG</span></p>
                            <div class="footer-map mt-2">
                                <iframe
                                    src="https://maps.google.com/maps?q=Rua+Jos%C3%A9+Lima+de+Almeida,+59,+Floramar,+Belo+Horizonte,+MG&output=embed"
                                    width="100%" height="130" style="border:0;border-radius:8px;filter:grayscale(30%)" allowfullscreen="" loading="lazy"
                                    referrerpolicy="no-referrer-when-downgrade"
                                    title="Localização da Comunidade Batista Floramar">
                                </iframe>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="footer-links">
                            <h6>Links rápidos</h6>
                            <ul>
                                <li><a href="/">Início</a></li>
                                <li><a href="/Sobre">Sobre</a></li>
                                <li><a href="/Cultos">Cultos</a></li>
                                <li><a href="/Celula">Células</a></li>
                                <li><a href="/Ministerios">Ministérios</a></li>
                                <li><a href="/Aovivo">Ao Vivo</a></li>
                                <li><a href="/Podcast">Podcast</a></li>
                                <li><a href="/PalavraDoPastor">Palavra do Pastor</a></li>
                                <li><a href="/Series">Séries</a></li>
                                <li><a href="/Doacao">Doações</a></li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="footer-social-block">
                            <h5>Redes sociais</h5>
                            <div class="social-links">
                                <a href="https://www.facebook.com/batistafloramar/" target="_blank" rel="noopener noreferrer" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                                <a href="https://www.instagram.com/batistafloramar/" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                                <a href="https://www.youtube.com/@@comunidadebatistafloramar" target="_blank" rel="noopener noreferrer" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="footer-copy text-center mt-4">
                    <p class="mb-0 text-secondary">&copy; @DateTime.Now.Year Comunidade Batista Floramar. Todos os direitos reservados.</p>
                    <p class="mb-0 mt-2" style="font-size:0.8rem;color:#888;">
                        Desenvolvido por
                        <span class="dev-credit">Caio Felipe V. Carvalho</span>
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <!-- Botão flutuante: menu rápido + voltar ao topo -->
    <div id="floatNav" class="float-nav d-none">
        <button class="float-nav-btn" id="floatMenuBtn" title="Menu" onclick="toggleFloatMenu()" aria-label="Abrir menu">
            <i class="fas fa-bars" id="floatMenuIcon"></i>
        </button>
        <div class="float-nav-menu" id="floatMenu">
            <a href="/" class="float-nav-link"><i class="fas fa-home"></i><span>Início</span></a>
            <a href="/Sobre" class="float-nav-link"><i class="fas fa-church"></i><span>Sobre</span></a>
            <a href="/Cultos" class="float-nav-link"><i class="fas fa-praying-hands"></i><span>Cultos</span></a>
            <a href="/Celula" class="float-nav-link"><i class="fas fa-home"></i><span>Células</span></a>
            <a href="/Ministerios" class="float-nav-link"><i class="fas fa-hands-helping"></i><span>Ministérios</span></a>
            <a href="/Aovivo" class="float-nav-link"><i class="fas fa-video"></i><span>Ao Vivo</span></a>
            <a href="/Podcast" class="float-nav-link"><i class="fas fa-podcast"></i><span>Podcast</span></a>
            <a href="/PalavraDoPastor" class="float-nav-link"><i class="fas fa-bible"></i><span>Palavra</span></a>
            <a href="/Series" class="float-nav-link"><i class="fas fa-film"></i><span>Séries</span></a>
            <a href="/Doacao" class="float-nav-link"><i class="fas fa-heart"></i><span>Doações</span></a>
            <a href="/Napalavra" class="float-nav-link"><i class="fas fa-envelope"></i><span>Contato</span></a>
            <button class="float-nav-link float-nav-top" onclick="scrollToTop()" title="Voltar ao topo">
                <i class="fas fa-arrow-up"></i><span>Topo</span>
            </button>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Mostrar/ocultar botão flutuante ao rolar
        const floatNav = document.getElementById('floatNav');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 300) floatNav.classList.remove('d-none');
            else { floatNav.classList.remove('d-none'); floatNav.classList.add('d-none'); }
            // fecha menu se rolar
            document.getElementById('floatMenu').classList.remove('open');
            document.getElementById('floatMenuIcon').className = 'fas fa-bars';
        }, { passive: true });

        function toggleFloatMenu() {
            const menu = document.getElementById('floatMenu');
            const icon = document.getElementById('floatMenuIcon');
            const open = menu.classList.toggle('open');
            icon.className = open ? 'fas fa-times' : 'fas fa-bars';
        }

        function scrollToTop() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
            document.getElementById('floatMenu').classList.remove('open');
            document.getElementById('floatMenuIcon').className = 'fas fa-bars';
        }

        // Fecha ao clicar fora
        document.addEventListener('click', (e) => {
            if (!document.getElementById('floatNav').contains(e.target)) {
                document.getElementById('floatMenu').classList.remove('open');
                document.getElementById('floatMenuIcon').className = 'fas fa-bars';
            }
        });

        // Scroll-reveal: observa elementos com classe .scroll-reveal
        (function () {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.12 });
            document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
        })();

        // Navbar scroll-shrink
        (function () {
            const navbar = document.querySelector('.main-navbar');
            if (!navbar) return;
            function onScroll() {
                navbar.classList.toggle('scrolled', window.scrollY > 40);
            }
            window.addEventListener('scroll', onScroll, { passive: true });
            onScroll();
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Aviso Ao Vivo -->
    <div id="aovivo-banner" style="display:none;" role="alert" aria-live="polite">
        <span class="aovivo-pulse"></span>
        <span class="aovivo-texto">Estamos ao vivo agora</span>
        <a id="aovivo-btn" href="https://www.youtube.com/@@igrejabatistafloramar" target="_blank" rel="noopener noreferrer" class="aovivo-assistir">
            <i class="fas fa-play me-1"></i>Assistir ao vivo
        </a>
        <button class="aovivo-fechar" id="aovivo-fechar" aria-label="Fechar aviso">
            <i class="fas fa-times"></i>
        </button>
    </div>
    <style>
        #aovivo-banner {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
            display: flex;
            align-items: center;
            gap: .75rem;
            background: #1a1a2e;
            border: 1px solid rgba(230,193,90,.3);
            border-left: 4px solid #e53e3e;
            border-radius: 12px;
            padding: .75rem 1.1rem;
            box-shadow: 0 8px 32px rgba(0,0,0,.55);
            max-width: 340px;
            animation: aovivo-slide-in .4s ease;
        }
        @@keyframes aovivo-slide-in {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .aovivo-pulse {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: #e53e3e;
            flex-shrink: 0;
            animation: aovivo-pulsar 1.4s ease-in-out infinite;
        }
        @@keyframes aovivo-pulsar {
            0%, 100% { box-shadow: 0 0 0 0 rgba(229,62,62,.6); }
            50%       { box-shadow: 0 0 0 8px rgba(229,62,62,0); }
        }
        .aovivo-texto {
            color: #fff;
            font-size: .9rem;
            font-weight: 600;
            white-space: nowrap;
        }
        .aovivo-assistir {
            background: linear-gradient(135deg, #E6C15A, #c9a63c);
            color: #1a1a1a;
            font-size: .82rem;
            font-weight: 700;
            padding: .38rem .9rem;
            border-radius: 20px;
            text-decoration: none;
            white-space: nowrap;
            transition: opacity .2s;
        }
        .aovivo-assistir:hover { opacity: .88; color: #1a1a1a; }
        .aovivo-fechar {
            background: none;
            border: none;
            color: #888;
            cursor: pointer;
            padding: 0 0 0 .25rem;
            font-size: .9rem;
            line-height: 1;
            flex-shrink: 0;
        }
        .aovivo-fechar:hover { color: #fff; }
        @@media (max-width: 575.98px) {
            #aovivo-banner {
                bottom: 16px;
                right: 12px;
                left: 12px;
                max-width: none;
                border-radius: 10px;
            }
            .aovivo-texto { font-size: .82rem; }
        }
    </style>
    <script>
        (function () {
            const YOUTUBE_URL = 'https://www.youtube.com/@@comunidadebatistafloramar';
            document.getElementById('aovivo-btn').href = YOUTUBE_URL;

            function estaAoVivo() {
                // Horário do Brasil: UTC-3
                const agora = new Date();
                const offsetBrasil = -3 * 60; // minutos
                const utcMs = agora.getTime() + agora.getTimezoneOffset() * 60000;
                const brasilDate = new Date(utcMs + offsetBrasil * 60000);

                const dia = brasilDate.getDay();    // 0=Dom, 3=Qua
                const h   = brasilDate.getHours();
                const m   = brasilDate.getMinutes();
                const hm  = h * 60 + m;             // minutos desde meia-noite

                // Domingo 10:00 – 12:00
                if (dia === 0 && hm >= 600 && hm < 720) return true;
                // Quarta 20:00 – 21:15
                if (dia === 3 && hm >= 1200 && hm < 1275) return true;
                return false;
            }

            function mostrarBanner() {
                if (estaAoVivo()) {
                    document.getElementById('aovivo-banner').style.display = 'flex';
                }
            }

            document.getElementById('aovivo-fechar').addEventListener('click', function () {
                document.getElementById('aovivo-banner').style.display = 'none';
            });

            mostrarBanner();
            // Verifica a cada minuto (para caso a página fique aberta)
            setInterval(mostrarBanner, 60000);
        })();
    </script>
</body>
</html>

