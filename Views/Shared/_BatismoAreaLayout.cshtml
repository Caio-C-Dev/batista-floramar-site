<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title — Área do Batismo | Comunidade Batista Floramar</title>
    <link rel="icon" type="image/png" href="~/images/church-logo.png" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
<div class="admin-wrapper">

    <!-- Sidebar -->
    <aside class="admin-sidebar">
        <div class="admin-brand">
            <i class="fas fa-water" style="font-size:1.5rem; color: var(--admin-accent);"></i>
            <span>Batismo</span>
        </div>
        <nav class="admin-nav">
            <a href="@Url.Action("Index", "AreaBatismo")"
               class="@(ViewBag.Section == "dashboard" ? "active" : "")">
                <i class="fas fa-tachometer-alt"></i>
                <span>Dashboard</span>
            </a>
            <a href="@Url.Action("Aulas", "AreaBatismo")"
               class="@(ViewBag.Section == "aulas" ? "active" : "")">
                <i class="fas fa-book-open"></i>
                <span>Aulas</span>
            </a>
            <a href="@Url.Action("Batizados", "AreaBatismo")"
               class="@(ViewBag.Section == "batizados" ? "active" : "")">
                <i class="fas fa-star-of-david"></i>
                <span>Histórico de Batizados</span>
            </a>
            <hr class="admin-nav-divider" />
            <a href="/">
                <i class="fas fa-globe"></i>
                <span>Ver Site</span>
            </a>
            <a href="@Url.Action("Logout", "AreaBatismo")" class="text-danger">
                <i class="fas fa-sign-out-alt"></i>
                <span>Sair</span>
            </a>
        </nav>
    </aside>

    <!-- Main -->
    <div class="admin-content">
        <div class="admin-topbar">
            <h1>@ViewBag.Title</h1>
            <div class="admin-topbar-actions">
                @RenderSection("TopbarActions", required: false)
                <span style="font-size:0.82rem;color:var(--admin-text-muted);display:flex;align-items:center;gap:0.4rem;">
                    <i class="fas fa-user-circle" style="color:var(--admin-accent);"></i>
                    @User.Identity?.Name
                </span>
                <a href="/" class="btn-admin-outline" style="font-size:0.82rem;">
                    <i class="fas fa-arrow-left"></i> Voltar ao Site
                </a>
            </div>
        </div>
        <div class="admin-main">
            @if (TempData["Sucesso"] != null)
            {
                <div class="alert-admin-success">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Sucesso"]
                </div>
            }
            @if (TempData["Erro"] != null)
            {
                <div class="alert-admin-error">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["Erro"]
                </div>
            }
            @RenderBody()
        </div>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
