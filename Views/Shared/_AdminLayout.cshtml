<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title — Admin | Comunidade Batista Floramar</title>
    <link rel="icon" type="image/png" href="~/images/church-logo.png" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
<div class="admin-wrapper">

    <!-- Sidebar -->
    <aside class="admin-sidebar">
        <div class="admin-brand">
            <i class="fas fa-cross" style="font-size:1.5rem; color: var(--admin-accent);"></i>
            <span>Admin</span>
        </div>
        <nav class="admin-nav">
            <a href="@Url.Action("Index", "Admin")"
               class="@(ViewBag.AdminSection == "dashboard" ? "active" : "")">
                <i class="fas fa-tachometer-alt"></i>
                <span>Dashboard</span>
            </a>
            <a href="@Url.Action("Index", "AdminCelulas")"
               class="@(ViewBag.AdminSection == "celulas" ? "active" : "")">
                <i class="fas fa-users"></i>
                <span>Células</span>
            </a>
            <a href="@Url.Action("Index", "AdminMinisterios")"
               class="@(ViewBag.AdminSection == "ministerios" ? "active" : "")">
                <i class="fas fa-church"></i>
                <span>Ministérios</span>
            </a>
            <a href="@Url.Action("Index", "AdminPodcasts")"
               class="@(ViewBag.AdminSection == "podcasts" ? "active" : "")">
                <i class="fab fa-youtube"></i>
                <span>Podcast</span>
            </a>
            <a href="@Url.Action("Index", "AdminPalavra")"
               class="@(ViewBag.AdminSection == "palavra" ? "active" : "")">
                <i class="fas fa-pen-nib"></i>
                <span>Palavra do Pastor</span>
            </a>
            <a href="@Url.Action("Index", "AdminSeries")"
               class="@(ViewBag.AdminSection == "series" ? "active" : "")">
                <i class="fab fa-youtube"></i>
                <span>Séries</span>
            </a>
            <a href="@Url.Action("Index", "AdminMensagens")"
               class="@(ViewBag.AdminSection == "mensagens" ? "active" : "")">
                <i class="fas fa-envelope"></i>
                <span>Mensagens</span>
            </a>
            <a href="@Url.Action("Index", "AdminEventos")"
               class="@(ViewBag.AdminSection == "eventos" ? "active" : "")">
                <i class="fas fa-calendar-alt"></i>
                <span>Eventos</span>
            </a>
            <a href="@Url.Action("Index", "AdminEventosSemanal")"
               class="@(ViewBag.AdminSection == "eventos-semanais" ? "active" : "")">
                <i class="fas fa-calendar-week"></i>
                <span>Agenda Semanal</span>
            </a>
            <a href="@Url.Action("Index", "AdminBatismo")"
               class="@(ViewBag.AdminSection == "batismo" ? "active" : "")">
                <i class="fas fa-water"></i>
                <span>Batismo / Filiação</span>
            </a>
            <a href="@Url.Action("Index", "AdminGaleria")"
               class="@(ViewBag.AdminSection == "galeria" ? "active" : "")">
                <i class="fas fa-images"></i>
                <span>Galeria</span>
            </a>
            @if (User.Identity?.Name == "AdmCaio")
            {
            <a href="@Url.Action("Index", "AdminUsuarios")"
               class="@(ViewBag.AdminSection == "usuarios" ? "active" : "")">
                <i class="fas fa-user-shield"></i>
                <span>Usuários</span>
            </a>
            }
            <hr class="admin-nav-divider" />
            <a href="/">
                <i class="fas fa-globe"></i>
                <span>Ver Site</span>
            </a>
            <a href="@Url.Action("Logout", "Admin")" class="text-danger">
                <i class="fas fa-sign-out-alt"></i>
                <span>Sair</span>
            </a>
        </nav>
    </aside>

    <!-- Main -->
    <div class="admin-content">
        <div class="admin-topbar">
            <h1>@ViewBag.Title</h1>
            <div class="admin-topbar-actions">
                @RenderSection("TopbarActions", required: false)
                <span style="font-size:0.82rem;color:var(--admin-text-muted);display:flex;align-items:center;gap:0.4rem;">
                    <i class="fas fa-user-circle" style="color:var(--admin-accent);"></i>
                    @User.Identity?.Name
                </span>
                <a href="/" class="btn-admin-outline" style="font-size:0.82rem;">
                    <i class="fas fa-arrow-left"></i> Voltar ao Site
                </a>
            </div>
        </div>
        <div class="admin-main">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert-admin-success">
                    <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert-admin-error">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                </div>
            }
            @RenderBody()
        </div>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
