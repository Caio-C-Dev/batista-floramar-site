@using BatistaFloramar.Domain.Entities
@model IEnumerable<PerguntaPastor>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Mensagens Recebidas";
    ViewBag.AdminSection = "mensagens";
}

<div class="admin-card p-0">
    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Nome</th>
                    <th>Assunto</th>
                    <th>E-mail / Telefone</th>
                    <th style="width:90px;">Ver</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    <tr>
                        <td style="white-space:nowrap;">@m.DataEnvio.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@m.Nome</td>
                        <td>@m.Assunto</td>
                        <td>
                            @m.Email
                            @if (!string.IsNullOrEmpty(m.Telefone))
                            {
                                <span class="ms-1" style="color: var(--admin-text-muted);">| @m.Telefone</span>
                            }
                        </td>
                        <td>
                            <a href="@Url.Action("Detalhes", new { id = m.Id })" class="btn-admin-outline" title="Ver mensagem">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center" style="color: var(--admin-text-muted); padding: 32px;">Nenhuma mensagem recebida.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
