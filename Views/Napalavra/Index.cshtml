@model BatistaFloramar.Models.PerguntaPastorViewModel
@{
    ViewBag.Title = "Contato | Comunidade Batista Floramar BH";
    Layout = "_Layout";
    ViewBag.FullWidth = true;
}
<style>
    .contato-hero {
        background: radial-gradient(ellipse at top, var(--bg-tertiary) 0%, var(--bg-primary) 60%);
        padding: 5.5rem 0 4rem;
        text-align: center;
        border-bottom: 1px solid var(--brand-gold-border);
        position: relative;
        overflow: hidden;
    }
    .contato-hero::before {
        content: '';
        position: absolute; inset: 0;
        background: radial-gradient(ellipse 60% 50% at 50% 100%, var(--brand-gold-light) 0%, transparent 70%);
    }
    .contato-hero h1 { font-size: clamp(2rem,5vw,3.2rem); font-weight: 800; color: var(--text-primary); margin-bottom: 1rem; position: relative; }
    .contato-hero .section-eyebrow { position: relative; }
    .contato-hero p { color: var(--text-secondary); max-width: 620px; margin: 0 auto; font-size: 1.1rem; position: relative; }

    .contato-section { padding: 4.5rem 0; }

    .contato-card {
        background: var(--bg-tertiary);
        border: 1px solid rgba(255,255,255,.07);
        border-radius: calc(var(--radius) * 1.5);
        padding: 2rem;
        height: 100%;
        transition: border-color var(--transition-smooth);
    }
    .contato-card:hover { border-color: var(--brand-gold-border); }
    .contato-card h3 { color: var(--text-primary); font-weight: 700; margin-bottom: 1rem; }
</style>

<!-- Hero -->
<div class="contato-hero">
    <div class="container">
        <span class="section-eyebrow">Fale com a Church</span>
        <h1>Mensagens ao Pastor</h1>
        <p>Envie sua pergunta, pedido de oração ou mensagem ao pastor. Nossa equipe fará o encaminhamento com cuidado.</p>
    </div>
</div>

<!-- Formulário + Contatos -->
<div class="contato-section">
    <div class="container">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success mb-4 rounded-3" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            </div>
        }

        <div class="row g-4">
            <div class="col-md-5 scroll-reveal">
                <div class="contato-card">
                    <h3><i class="fas fa-address-book me-2 text-gold"></i>Contatos</h3>
                    <ul class="info-list mt-3">
                        <li><i class="fas fa-phone"></i><span>(31) 99289-8901</span></li>
                        <li><i class="fas fa-envelope"></i><span>c.batistafloramar&#64;gmail.com</span></li>
                        <li><i class="fas fa-map-marker-alt"></i><span>R. José Lima de Almeida, 59 — Jardim Guanabara, BH/MG, 31742-033</span></li>
                        <li><i class="fas fa-clock"></i><span>Dom: 10h (ao vivo) &nbsp;|&nbsp; Dom: 18h (presencial) &nbsp;|&nbsp; Qua: 20h (ao vivo)</span></li>
                    </ul>
                    <div class="mt-4">
                        <a href="https://wa.me/5531992898901" target="_blank" rel="noopener noreferrer" class="btn btn-primary w-100">
                            <i class="fab fa-whatsapp me-2"></i> WhatsApp
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-md-7 scroll-reveal delay-1">
                <div class="contato-card">
                    <h3><i class="fas fa-comment-dots me-2 text-gold"></i>Deixe sua mensagem</h3>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-warning mt-3 rounded-3" role="alert">
                            <i class="fas fa-exclamation-triangle me-2"></i> Confira os campos obrigatórios antes de enviar.
                        </div>
                    }

                    <form method="post" action="/Napalavra/Index" class="mt-3">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">Nome completo</label>
                            @Html.TextBoxFor(m => m.Nome, new { @class = "form-control", placeholder = "Seu nome completo" })
                            @Html.ValidationMessageFor(m => m.Nome, "", new { @class = "text-danger small" })
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Email</label>
                                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email", placeholder = "seu@email.com" })
                                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Telefone</label>
                                @Html.TextBoxFor(m => m.Telefone, new { @class = "form-control", placeholder = "(31) 99999-9999" })
                                @Html.ValidationMessageFor(m => m.Telefone, "", new { @class = "text-danger small" })
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Assunto</label>
                            @Html.TextBoxFor(m => m.Assunto, new { @class = "form-control", placeholder = "Ex.: Família, fé, oração..." })
                            @Html.ValidationMessageFor(m => m.Assunto, "", new { @class = "text-danger small" })
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mensagem</label>
                            @Html.TextAreaFor(m => m.Pergunta, new { @class = "form-control", rows = 5, placeholder = "Escreva aqui sua mensagem ou pergunta ao pastor..." })
                            @Html.ValidationMessageFor(m => m.Pergunta, "", new { @class = "text-danger small" })
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-paper-plane me-2"></i> Enviar mensagem
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
