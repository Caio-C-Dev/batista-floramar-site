@using BatistaFloramar.Domain.Entities
@model List<GaleriaAlbum>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Galeria de Fotos";
    ViewBag.AdminSection = "galeria";
}

@section TopbarActions {
    <a href="@Url.Action("NovoAlbum")" class="btn-admin btn-admin-success">
        <i class="fas fa-plus"></i> Novo Álbum
    </a>
}

<div class="admin-card">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fas fa-images"></i>
            <p>Nenhum álbum criado ainda.</p>
            <a href="@Url.Action("NovoAlbum")" class="btn-admin btn-admin-success">
                <i class="fas fa-plus"></i> Criar primeiro álbum
            </a>
        </div>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Capa</th>
                    <th>Nome</th>
                    <th>Data</th>
                    <th>Fotos</th>
                    <th style="width:160px">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var album in Model)
                {
                    var capa = album.Fotos.FirstOrDefault()?.CaminhoArquivo;
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(capa))
                            {
                                <img src="@capa" alt="@album.Nome" style="width:80px;height:52px;object-fit:cover;border-radius:7px;" />
                            }
                            else
                            {
                                <div style="width:80px;height:52px;border-radius:7px;background:#1a2844;display:flex;align-items:center;justify-content:center;">
                                    <i class="fas fa-images" style="color:#4a5a7a;"></i>
                                </div>
                            }
                        </td>
                        <td><strong>@album.Nome</strong><br><small style="color:#9aacb8;">@album.Descricao</small></td>
                        <td style="white-space:nowrap;">@album.Data.ToString("dd/MM/yyyy")</td>
                        <td><span class="badge-admin">@album.Fotos.Count foto@(album.Fotos.Count != 1 ? "s" : "")</span></td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="@Url.Action("EditarAlbum", new { id = album.Id })"
                                   class="btn-admin btn-admin-outline" style="font-size:.8rem;padding:.3rem .7rem;">
                                    <i class="fas fa-edit"></i> Editar
                                </a>
                                <form method="post" action="@Url.Action("ExcluirAlbum")"
                                      onsubmit="return confirm('Excluir álbum \'@album.Nome\' e todas as fotos?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@album.Id" />
                                    <button type="submit" class="btn-admin btn-admin-danger" style="font-size:.8rem;padding:.3rem .7rem;">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
