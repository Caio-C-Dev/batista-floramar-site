@model BatistaFloramar.Models.LiderRegistrarPresencaViewModel
@{
    ViewBag.Title = "Registrar Presença";
    Layout = "_Layout";
}

<div class="page-card" style="max-width:680px;margin:0 auto;">
    <div class="page-header">
        <span class="section-eyebrow">Área dos Líderes</span>
        <h1 class="page-title" style="font-size:1.8rem;">
            <i class="fas fa-clipboard-check me-2 text-gold"></i>Registrar Presença
        </h1>
    </div>

    <div class="section-card">
        <form asp-action="Presenca" asp-controller="Lider" method="post" id="formPresenca">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CelulaId" />

            <!-- Data -->
            <div class="mb-4">
                <label asp-for="Data" class="form-label fw-semibold text-white">Data da Reunião</label>
                <input asp-for="Data" type="date" class="form-control form-control-lg"
                       style="background:#1a2240;border-color:#2e3a5c;color:#fff;max-width:220px;" />
                <span asp-validation-for="Data" class="text-danger small"></span>
            </div>

            <!-- Tipo -->
            <div class="mb-4">
                <label class="form-label fw-semibold text-white">Tipo de Reunião</label>
                <div class="d-flex flex-wrap gap-3 mt-1">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Tipo"
                               value="Normal" id="tipoNormal" onchange="alternarListaPresenca()" />
                        <label class="form-check-label text-white" for="tipoNormal">
                            <i class="fas fa-check-circle me-1 text-gold"></i>Normal
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Tipo"
                               value="NaoHoveCelula" id="tipoNaoHouve" onchange="alternarListaPresenca()" />
                        <label class="form-check-label text-white" for="tipoNaoHouve">
                            <i class="fas fa-times-circle me-1 text-secondary"></i>Não houve célula
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Tipo"
                               value="CelulaLivre" id="tipoCelulaLivre" onchange="alternarListaPresenca()" />
                        <label class="form-check-label text-white" for="tipoCelulaLivre">
                            <i class="fas fa-star me-1 text-gold"></i>Célula livre
                        </label>
                    </div>
                </div>
                <span asp-validation-for="Tipo" class="text-danger small"></span>
            </div>

            <!-- Lista de integrantes (Normal e Célula livre) -->
            <div id="listaIntegrantes">
                @if (Model.Integrantes.Any())
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                            <label class="form-label fw-semibold text-white mb-0">
                                <i class="fas fa-users me-1 text-gold"></i>Integrantes
                            </label>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="marcarTodos(true)">
                                    Todos presentes
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="marcarTodos(false)">
                                    Nenhum
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="list-group list-group-flush mb-4">
                        @for (int i = 0; i < Model.Integrantes.Count; i++)
                        {
                            var item = Model.Integrantes[i];
                            <div class="list-group-item px-0 py-3" style="background:transparent;border-color:#2e3a5c;">
                                <input type="hidden" name="Integrantes[@i].IntegranteId" value="@item.IntegranteId" />
                                <input type="hidden" name="Integrantes[@i].Nome" value="@item.Nome" />

                                <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
                                    <!-- Nome + toggle -->
                                    <div class="d-flex align-items-center gap-3 flex-grow-1">
                                        <div class="form-check form-switch mb-0">
                                            <input class="form-check-input presenca-toggle" type="checkbox"
                                                   name="Integrantes[@i].Presente" value="true"
                                                   id="pres_@item.IntegranteId"
                                                   onchange="toggleJustificativa(@item.IntegranteId, this.checked)"
                                                   style="width:3rem;height:1.5rem;cursor:pointer;" />
                                        </div>
                                        <label for="pres_@item.IntegranteId" class="text-white fw-semibold mb-0" style="cursor:pointer;">
                                            @item.Nome
                                        </label>
                                    </div>
                                    <!-- Status badge -->
                                    <span id="badge_@item.IntegranteId" class="badge" style="background:#3a1a1a;color:#e74c3c;min-width:80px;text-align:center;">
                                        Faltou
                                    </span>
                                </div>

                                <!-- Justificativa (aparece ao marcar falta) -->
                                <div id="just_@item.IntegranteId" class="mt-2">
                                    <input type="text" name="Integrantes[@i].Justificativa"
                                           class="form-control form-control-sm"
                                           style="background:#1a2240;border-color:#2e3a5c;color:#fff;"
                                           placeholder="Motivo da falta (ex.: viagem, doença...)" maxlength="500" />
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-warning d-flex gap-2 align-items-center mb-4">
                        <i class="fas fa-exclamation-triangle"></i>
                        <span>Nenhum integrante cadastrado. <a href="@Url.Action("Dashboard", "Lider")" class="alert-link">Adicione integrantes</a> antes de registrar presença.</span>
                    </div>
                }
            </div>

            <!-- Botões -->
            <div class="d-flex gap-3 flex-wrap">
                <button type="submit" class="btn btn-primary btn-lg px-5">
                    <i class="fas fa-save me-2"></i>Salvar
                </button>
                <a href="@Url.Action("Dashboard", "Lider")" class="btn btn-outline-secondary btn-lg">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function alternarListaPresenca() {
        const tipo = document.querySelector('input[name="Tipo"]:checked')?.value;
        const lista = document.getElementById('listaIntegrantes');
        // Normal e Célula Livre mostram a lista; "Não houve célula" oculta
        lista.style.display = (tipo === 'Normal' || tipo === 'CelulaLivre') ? '' : 'none';
    }

    function toggleJustificativa(id, presente) {
        const just = document.getElementById('just_' + id);
        const badge = document.getElementById('badge_' + id);
        if (presente) {
            just.style.display = 'none';
            badge.style.background = '#1a3a2a';
            badge.style.color = '#27c9a2';
            badge.textContent = 'Presente';
        } else {
            just.style.display = '';
            badge.style.background = '#3a1a1a';
            badge.style.color = '#e74c3c';
            badge.textContent = 'Faltou';
        }
    }

    function marcarTodos(valor) {
        document.querySelectorAll('.presenca-toggle').forEach(cb => {
            cb.checked = valor;
            const id = cb.id.replace('pres_', '');
            toggleJustificativa(id, valor);
        });
    }

    // Inicializa estados
    alternarListaPresenca();
    document.querySelectorAll('.presenca-toggle').forEach(cb => {
        const id = cb.id.replace('pres_', '');
        toggleJustificativa(id, cb.checked);
    });
</script>
}
