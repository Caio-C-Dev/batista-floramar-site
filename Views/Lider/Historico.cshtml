@model BatistaFloramar.Models.LiderHistoricoViewModel
@{
    ViewBag.Title = "Histórico de Presença";
    Layout = "_Layout";
}

<div class="page-card">
    <div class="page-header d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <span class="section-eyebrow">Área dos Líderes</span>
            <h1 class="page-title mb-0" style="font-size:1.8rem;">
                <i class="fas fa-history me-2 text-gold"></i>Histórico de Presença
            </h1>
            <p class="text-secondary mb-0 mt-1">@Model.NomeCelula</p>
        </div>
        <a href="@Url.Action("Dashboard", "Lider")" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Voltar
        </a>
    </div>

    @if (!Model.Presencas.Any())
    {
        <div class="section-card mt-4 text-center py-5">
            <i class="fas fa-calendar-times text-secondary" style="font-size:3rem;"></i>
            <p class="text-secondary mt-3">Nenhuma presença registrada ainda.</p>
            <a href="@Url.Action("Presenca", "Lider")" class="btn btn-primary mt-2">
                <i class="fas fa-clipboard-check me-2"></i>Registrar primeira presença
            </a>
        </div>
    }
    else
    {
        var meses = new[] { "", "Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho",
                            "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro" };

        var grupos = Model.Presencas
            .GroupBy(p => new { p.Data.Year, p.Data.Month })
            .OrderByDescending(g => g.Key.Year)
            .ThenByDescending(g => g.Key.Month);

        foreach (var grupo in grupos)
        {
            var tituloMes = $"{meses[grupo.Key.Month]} {grupo.Key.Year}";
            var totalGrupo = grupo.Sum(p => p.Detalhes.Count);
            var presentesGrupo = grupo.Sum(p => p.Detalhes.Count(d => d.Presente));
            var pctGrupo = totalGrupo > 0 ? (int)Math.Round((double)presentesGrupo / totalGrupo * 100) : -1;
            var corMes = pctGrupo >= 75 ? "#27c9a2" : pctGrupo >= 50 ? "#c9a227" : pctGrupo >= 0 ? "#e74c3c" : "#888";

            <div class="section-card mt-4">
                <!-- Cabeçalho do mês -->
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                    <h2 class="text-gold mb-0" style="font-size:1.2rem;">
                        <i class="fas fa-calendar-alt me-2"></i>@tituloMes
                        <span class="text-secondary fw-normal ms-1" style="font-size:.85rem;">
                            (@grupo.Count() reuni@(grupo.Count() == 1 ? "ão" : "ões"))
                        </span>
                    </h2>
                    @if (pctGrupo >= 0)
                    {
                        <span class="badge px-3 py-2" style="background:#1a2240;color:@corMes;font-size:.85rem;">
                            Média do mês: @pctGrupo%
                        </span>
                    }
                </div>

                <!-- Reuniões do mês -->
                @foreach (var p in grupo.OrderByDescending(x => x.Data))
                {
                    var tipoLabel = p.Tipo switch {
                        "Normal" => "Normal",
                        "NaoHoveCelula" => "Não houve célula",
                        "CelulaLivre" => "Célula livre",
                        _ => p.Tipo
                    };
                    var tipoClass = p.Tipo == "Normal" ? "text-gold" : p.Tipo == "CelulaLivre" ? "text-gold" : "text-secondary";

                    <div class="mb-3 pb-3" style="border-bottom:1px solid #2e3a5c;">
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
                            <span class="fw-semibold text-white">
                                <i class="fas fa-calendar-day me-1 text-gold" style="font-size:.85rem;"></i>
                                @p.Data.ToString("dd/MM/yyyy")
                                <span class="@tipoClass ms-2 small fw-normal">@tipoLabel</span>
                            </span>
                            @if (p.Detalhes.Any())
                            {
                                var presentes = p.Detalhes.Count(d => d.Presente);
                                var total = p.Detalhes.Count;
                                var pct = total > 0 ? (int)Math.Round((double)presentes / total * 100) : 0;
                                var corPct = pct >= 75 ? "#27c9a2" : pct >= 50 ? "#c9a227" : "#e74c3c";
                                <span class="badge" style="background:#0b1224;color:@corPct;">
                                    @presentes / @total (@pct%)
                                </span>
                            }
                        </div>

                        @if (p.Detalhes.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-dark table-sm mb-0" style="--bs-table-bg:transparent;font-size:.88rem;">
                                    <thead>
                                        <tr style="color:#c9a227;">
                                            <th>Integrante</th>
                                            <th style="width:100px;">Situação</th>
                                            <th>Motivo da falta</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var d in p.Detalhes)
                                        {
                                            <tr>
                                                <td class="text-white">@d.NomeIntegrante</td>
                                                <td>
                                                    @if (d.Presente)
                                                    {
                                                        <span class="badge" style="background:#1a3a2a;color:#27c9a2;">
                                                            <i class="fas fa-check me-1"></i>Presente
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge" style="background:#3a1a1a;color:#e74c3c;">
                                                            <i class="fas fa-times me-1"></i>Faltou
                                                        </span>
                                                    }
                                                </td>
                                                <td class="text-secondary">@(d.Justificativa ?? "—")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-secondary small mb-0"><em>Sem detalhes de presença registrados.</em></p>
                        }
                    </div>
                }
            </div>
        }
    }
</div>
