@model BatistaFloramar.Models.LiderLoginViewModel
@{
    ViewBag.Title = "Área dos Líderes";
    Layout = "_Layout";
    ViewBag.MetaDescription = "Acesso restrito para líderes de célula da Comunidade Batista Floramar.";
}

<div class="page-card" style="max-width: 460px; margin: 0 auto;">
    <div class="page-header text-center">
        <span class="section-eyebrow">Área Restrita</span>
        <h1 class="page-title" style="font-size:1.8rem;">
            <i class="fas fa-users me-2 text-gold"></i>Área dos Líderes
        </h1>
        <p class="page-subtitle">
            Acesso exclusivo para líderes de célula.
        </p>
    </div>

    <div class="section-card">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4" role="alert">
                <i class="fas fa-exclamation-circle"></i>
                <div>
                    @foreach (var erro in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <span>@erro.ErrorMessage</span>
                    }
                </div>
            </div>
        }

        <form asp-action="Login" asp-controller="Lider" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <div class="mb-4">
                <label asp-for="NomeCelula" class="form-label fw-semibold text-white"></label>
                <div class="input-group">
                    <span class="input-group-text" style="background:#1a2240;border-color:#2e3a5c;color:#c9a227;">
                        <i class="fas fa-home"></i>
                    </span>
                    <input asp-for="NomeCelula" class="form-control form-control-lg"
                           style="background:#1a2240;border-color:#2e3a5c;color:#fff;"
                           placeholder="Ex.: Floramar Norte"
                           autocomplete="username" />
                </div>
                <span asp-validation-for="NomeCelula" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="NomeLider" class="form-label fw-semibold text-white"></label>
                <div class="input-group">
                    <span class="input-group-text" style="background:#1a2240;border-color:#2e3a5c;color:#c9a227;">
                        <i class="fas fa-lock"></i>
                    </span>
                    <input asp-for="NomeLider" type="password" class="form-control form-control-lg"
                           style="background:#1a2240;border-color:#2e3a5c;color:#fff;"
                           placeholder="Senha"
                           autocomplete="current-password" />
                </div>
                <span asp-validation-for="NomeLider" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 btn-lg py-3">
                <i class="fas fa-sign-in-alt me-2"></i>Entrar
            </button>
        </form>

        <div class="text-center mt-4">
            <a href="/Celula" class="text-secondary small">
                <i class="fas fa-arrow-left me-1"></i>Voltar para Células
            </a>
        </div>
    </div>
</div>
