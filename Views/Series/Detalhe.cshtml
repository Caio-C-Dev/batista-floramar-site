@model BatistaFloramar.Domain.Entities.SerieMensagem
@{
    ViewBag.Title = Model.Nome;
    Layout = "_Layout";
}

<div class="page-card">
    <div class="page-header">
        <span class="section-eyebrow">Séries de Mensagens</span>
        <h1 class="page-title">@Model.Nome</h1>
        @if (!string.IsNullOrEmpty(Model.Descricao))
        {
            <p class="page-subtitle">@Model.Descricao</p>
        }
    </div>

    <div class="section-card mt-4 p-0" style="overflow:hidden;">
        <div style="position:relative;width:100%;padding-bottom:56.25%;background:#000;">
            <iframe
                src="https://www.youtube.com/embed/videoseries?list=@Model.PlaylistId&hl=pt-BR"
                title="@Model.Nome"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
                style="position:absolute;top:0;left:0;width:100%;height:100%;border:0;">
            </iframe>
        </div>
    </div>

    <div class="mt-4 d-flex align-items-center gap-3 flex-wrap">
        <a href="@Url.Action("Index", "Series")" class="btn-outline-gold">
            <i class="fas fa-arrow-left me-2"></i>Voltar às séries
        </a>
        <a href="https://www.youtube.com/playlist?list=@Model.PlaylistId"
           target="_blank" rel="noopener noreferrer"
           style="color:#ff4444;font-size:.9rem;">
            <i class="fab fa-youtube me-1"></i> Abrir no YouTube
        </a>
    </div>
</div>
